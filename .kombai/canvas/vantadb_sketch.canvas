      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600&family=Outfit:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --void: #050507;\n    --surface: #0f1014;\n    --raised: #16181d;\n    --amber: #ff6a00;\n    --steel: #8b9eb7;\n    --foreground: #f7f5f2;\n    --border: #22252b;\n    --font-display: 'Space Grotesk', sans-serif;\n    --font-body: 'Outfit', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--void);\n    color: var(--foreground);\n    font-family: var(--font-body);\n    margin: 0;\n    padding: 0;\n    line-height: 1.6;\n    overflow-x: hidden;\n  }\n\n  /* --- Navigation --- */\n  nav {\n    height: 72px;\n    display: flex;\n    align-items: center;\n    padding: 0 48px;\n    border-bottom: 1px solid var(--border);\n    background: rgba(5, 5, 7, 0.8);\n    backdrop-filter: blur(12px);\n    position: sticky;\n    top: 0;\n    z-index: 100;\n  }\n\n  .nav-logo {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    font-family: var(--font-display);\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n  }\n\n  .nav-links {\n    margin-left: auto;\n    display: flex;\n    gap: 32px;\n  }\n\n  .nav-link {\n    font-family: var(--font-mono);\n    font-size: 0.75rem;\n    color: var(--steel);\n    text-decoration: none;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    transition: color 0.2s;\n  }\n\n  .nav-link:hover {\n    color: var(--amber);\n  }\n\n  /* --- Hero --- */\n  .hero {\n    padding: 120px 48px 80px;\n    max-width: 1200px;\n    margin: 0 auto;\n    position: relative;\n  }\n\n  .hero-eyebrow {\n    font-family: var(--font-mono);\n    color: var(--amber);\n    text-transform: uppercase;\n    letter-spacing: 0.15em;\n    font-size: 0.8rem;\n    margin-bottom: 24px;\n    display: block;\n  }\n\n  .hero-title {\n    font-family: var(--font-display);\n    font-size: 5rem;\n    line-height: 1;\n    letter-spacing: -0.04em;\n    margin-bottom: 32px;\n    max-width: 900px;\n  }\n\n  .hero-sub {\n    font-size: 1.25rem;\n    color: var(--steel);\n    max-width: 650px;\n  }\n\n  /* --- Architecture Layers --- */\n  .layers-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 64px;\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 80px 48px;\n    align-items: start;\n  }\n\n  .layer-item {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    padding: 40px;\n    position: relative;\n    overflow: hidden;\n    transition: transform 0.3s ease, border-color 0.3s ease;\n  }\n\n  .layer-item:hover {\n    transform: translateY(-4px);\n    border-color: var(--amber);\n    background: var(--raised);\n  }\n\n  .layer-num {\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--steel);\n    opacity: 0.5;\n    margin-bottom: 12px;\n    display: block;\n  }\n\n  .layer-title {\n    font-family: var(--font-display);\n    font-size: 2.25rem;\n    margin-bottom: 20px;\n    color: var(--foreground);\n  }\n\n  .layer-desc {\n    color: var(--steel);\n    margin-bottom: 32px;\n  }\n\n  .layer-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 12px;\n  }\n\n  .tag {\n    font-family: var(--font-mono);\n    font-size: 0.65rem;\n    background: rgba(139, 158, 183, 0.05);\n    border: 1px solid var(--border);\n    padding: 4px 10px;\n    border-radius: 4px;\n    color: var(--steel);\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n  }\n\n  /* --- Operational Specs Table --- */\n  .specs-section {\n    padding: 120px 48px;\n    background: var(--surface);\n    border-top: 1px solid var(--border);\n  }\n\n  .specs-container {\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n\n  .section-head {\n    margin-bottom: 64px;\n  }\n\n  .specs-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-family: var(--font-mono);\n  }\n\n  .specs-table th {\n    text-align: left;\n    padding: 24px;\n    border-bottom: 1px solid var(--border);\n    color: var(--steel);\n    font-size: 0.7rem;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n  }\n\n  .specs-table td {\n    padding: 24px;\n    border-bottom: 1px solid var(--border);\n    vertical-align: top;\n  }\n\n  .spec-label {\n    color: var(--foreground);\n    font-weight: 500;\n  }\n\n  .spec-value {\n    color: var(--amber);\n  }\n\n  .spec-desc {\n    color: var(--steel);\n    font-family: var(--font-body);\n    font-size: 0.95rem;\n  }\n\n  /* --- Visual Components --- */\n  .flamegraph-box {\n    background: var(--void);\n    border: 1px solid var(--border);\n    padding: 32px;\n    border-radius: 12px;\n    margin-top: 80px;\n    position: relative;\n  }\n\n  .flame-title {\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--steel);\n    margin-bottom: 24px;\n    display: block;\n  }\n\n  .flame-bars {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n\n  .flame-bar {\n    height: 24px;\n    background: var(--amber);\n    opacity: 0.1;\n    position: relative;\n    border-radius: 2px;\n  }\n\n  .flame-bar::after {\n    content: attr(data-label);\n    position: absolute;\n    left: 12px;\n    top: 50%;\n    transform: translateY(-50%);\n    font-size: 0.65rem;\n    font-family: var(--font-mono);\n    color: var(--foreground);\n  }\n\n  /* --- Footer --- */\n  footer {\n    padding: 80px 48px;\n    border-top: 1px solid var(--border);\n    text-align: center;\n  }\n\n  .footer-copy {\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--border);\n    text-transform: uppercase;\n    letter-spacing: 0.15em;\n  }\n\n  /* --- Animations --- */\n  @keyframes scanline {\n    0% { transform: translateY(-100%); }\n    100% { transform: translateY(100%); }\n  }\n\n  .scanline-overlay {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: linear-gradient(to bottom, transparent, rgba(255,106,0,0.02) 50%, transparent);\n    pointer-events: none;\n    z-index: 1000;\n    animation: scanline 8s linear infinite;\n  }\n\n</style>\n\n<div class=\"scanline-overlay\" data-kid=\"1\"></div>\n\n<nav data-kid=\"2\">\n  <div class=\"nav-logo\" data-kid=\"3\">\n    <i class=\"ti ti-binary\" style=\"color: var(--amber);\" data-kid=\"4\"></i>\n    VantaDB\n  </div>\n  <div class=\"nav-links\" data-kid=\"5\">\n    <a href=\"#\" class=\"nav-link\" data-kid=\"6\">Home</a>\n    <a href=\"#\" class=\"nav-link\" data-kid=\"7\">Architecture</a>\n    <a href=\"#\" class=\"nav-link\" data-kid=\"8\">Benchmarks</a>\n    <a href=\"#\" class=\"nav-link\" data-kid=\"9\">Docs</a>\n  </div>\n</nav>\n\n<section class=\"hero\" data-kid=\"10\">\n  <span class=\"hero-eyebrow\" data-kid=\"11\">// Deep Schematic</span>\n  <h1 class=\"hero-title\" data-kid=\"12\">Zero-copy from Python to Rust.</h1>\n  <p class=\"hero-sub\" data-kid=\"13\">VantaDB compiles to a single native library wrapper. No extra TCP connections, no separate processes to start. Just pure memory speed.</p>\n</section>\n\n<section class=\"layers-grid\" data-kid=\"14\">\n  \n  <div class=\"layer-item reveal\" data-kid=\"15\">\n    <span class=\"layer-num\" data-kid=\"16\">01 / PROCESS</span>\n    <h2 class=\"layer-title\" data-kid=\"17\">Python SDK</h2>\n    <p class=\"layer-desc\" data-kid=\"18\">Direct importable Python library offering namespace queries, hybrid search fusing, and structured JSON FFI calls. Zero-copy from Python to Rust runtime.</p>\n    <div class=\"layer-tags\" data-kid=\"19\">\n      <span class=\"tag\" data-kid=\"20\">vantadb.put()</span>\n      <span class=\"tag\" data-kid=\"21\">Zero-copy</span>\n      <span class=\"tag\" data-kid=\"22\">Python 3.10+</span>\n    </div>\n  </div>\n\n  \n  <div class=\"layer-item reveal\" data-kid=\"23\">\n    <span class=\"layer-num\" data-kid=\"24\">02 / INTERFACE</span>\n    <h2 class=\"layer-title\" data-kid=\"25\">PyO3 FFI Boundary</h2>\n    <p class=\"layer-desc\" data-kid=\"26\">Fast FFI boundary compilation translating Python dicts to Rust structs without heap allocation loops. Stable boundary guarantees no GIL contention.</p>\n    <div class=\"layer-tags\" data-kid=\"27\">\n      <span class=\"tag\" data-kid=\"28\">Rust Bridge</span>\n      <span class=\"tag\" data-kid=\"29\">No-GIL</span>\n      <span class=\"tag\" data-kid=\"30\">Struct Mapping</span>\n    </div>\n  </div>\n\n  \n  <div class=\"layer-item reveal\" data-kid=\"31\">\n    <span class=\"layer-num\" data-kid=\"32\">03 / ENGINE</span>\n    <h2 class=\"layer-title\" data-kid=\"33\">Core Engine</h2>\n    <p class=\"layer-desc\" data-kid=\"34\">Splits queries into lexical inverted indexes and HNSW indexes, calculating Reciprocal Rank Fusion (RRF) relevance in parallel across all available cores.</p>\n    <div class=\"layer-tags\" data-kid=\"35\">\n      <span class=\"tag\" data-kid=\"36\">BM25</span>\n      <span class=\"tag\" data-kid=\"37\">HNSW</span>\n      <span class=\"tag\" data-kid=\"38\">Parallel RRF</span>\n    </div>\n  </div>\n\n  \n  <div class=\"layer-item reveal\" data-kid=\"39\">\n    <span class=\"layer-num\" data-kid=\"40\">04 / STORAGE</span>\n    <h2 class=\"layer-title\" data-kid=\"41\">LSM-Tree Storage</h2>\n    <p class=\"layer-desc\" data-kid=\"42\">In-process log-structured merge-tree engine managing blocks, WAL buffers, compaction runs, and transaction safety with CRC32C integrity checks.</p>\n    <div class=\"layer-tags\" data-kid=\"43\">\n      <span class=\"tag\" data-kid=\"44\">WAL Sync</span>\n      <span class=\"tag\" data-kid=\"45\">CRC32C</span>\n      <span class=\"tag\" data-kid=\"46\">Fsync Durability</span>\n    </div>\n  </div>\n</section>\n\n<section class=\"specs-section\" data-kid=\"47\">\n  <div class=\"specs-container\" data-kid=\"48\">\n    <div class=\"section-head reveal\" data-kid=\"49\">\n      <span class=\"hero-eyebrow\" data-kid=\"50\">// Constraints</span>\n      <h2 class=\"hero-title\" style=\"font-size: 3.5rem;\" data-kid=\"51\">Operational Limits</h2>\n    </div>\n\n    <table class=\"specs-table reveal\" data-kid=\"52\">\n      <thead data-kid=\"53\">\n        <tr data-kid=\"54\">\n          <th data-kid=\"55\">Parameter</th>\n          <th data-kid=\"56\">Limit</th>\n          <th data-kid=\"57\">Behavioral Logic</th>\n        </tr>\n      </thead>\n      <tbody data-kid=\"58\">\n        <tr data-kid=\"59\">\n          <td class=\"spec-label\" data-kid=\"60\">Key Size Limit</td>\n          <td class=\"spec-value\" data-kid=\"61\">1 KB</td>\n          <td class=\"spec-desc\" data-kid=\"62\">Identifiers must be compact to ensure lightning-fast pointer indexing in standard LSM memory bounds.</td>\n        </tr>\n        <tr data-kid=\"63\">\n          <td class=\"spec-label\" data-kid=\"64\">Vector Dimensions</td>\n          <td class=\"spec-value\" data-kid=\"65\">32,768 dims</td>\n          <td class=\"spec-desc\" data-kid=\"66\">Optimized structures for high-end sparse embeddings, supporting up to 32k vector dimensions per node.</td>\n        </tr>\n        <tr data-kid=\"67\">\n          <td class=\"spec-label\" data-kid=\"68\">Text Content</td>\n          <td class=\"spec-value\" data-kid=\"69\">10 MB / put</td>\n          <td class=\"spec-desc\" data-kid=\"70\">Larger chunk payloads are offloaded directly to binary buffers, preserving planner heap latency floors.</td>\n        </tr>\n        <tr data-kid=\"71\">\n          <td class=\"spec-label\" data-kid=\"72\">Metadata Size</td>\n          <td class=\"spec-value\" data-kid=\"73\">64 KB</td>\n          <td class=\"spec-desc\" data-kid=\"74\">Structured dictionaries for lexical pre-filtering operations before RRF fusion runs.</td>\n        </tr>\n        <tr data-kid=\"75\">\n          <td class=\"spec-label\" data-kid=\"76\">Concurrency</td>\n          <td class=\"spec-value\" data-kid=\"77\">1W / ∞R</td>\n          <td class=\"spec-desc\" data-kid=\"78\">Safe thread concurrent read executions; write paths synchronize locks to protect journal logs.</td>\n        </tr>\n        <tr data-kid=\"79\">\n          <td class=\"spec-label\" data-kid=\"80\">Durability</td>\n          <td class=\"spec-value\" data-kid=\"81\">WAL + CRC32C</td>\n          <td class=\"spec-desc\" data-kid=\"82\">Atomic commit log with periodic fsync flushes. Defaults to 500ms intervals for high throughput.</td>\n        </tr>\n      </tbody>\n    </table>\n\n    <div class=\"flamegraph-box reveal\" data-kid=\"83\">\n      <span class=\"flame-title\" data-kid=\"84\">PROFILER_SESSION: 0XFF82 — HOT PATHS</span>\n      <div class=\"flame-bars\" data-kid=\"85\">\n        <div class=\"flame-bar\" style=\"width: 100%; opacity: 0.15;\" data-label=\"vantadb_core::query_handler\" data-kid=\"86\"></div>\n        <div class=\"flame-bar\" style=\"width: 85%; opacity: 0.3;\" data-label=\"hnsw::search_layer\" data-kid=\"87\"></div>\n        <div class=\"flame-bar\" style=\"width: 60%; opacity: 0.5;\" data-label=\"bm25::intersection_scan\" data-kid=\"88\"></div>\n        <div class=\"flame-bar\" style=\"width: 45%; opacity: 0.7;\" data-label=\"lsm_tree::wal_flush\" data-kid=\"89\"></div>\n        <div class=\"flame-bar\" style=\"width: 20%; background: var(--amber); opacity: 1;\" data-label=\"pyo3::ffi_boundary_handoff\" data-kid=\"90\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<footer data-kid=\"91\">\n  <div class=\"footer-copy\" data-kid=\"92\">© 2026 VANTADB — ARCHITECTURE SCHEMATIC V0.4.2</div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"93\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"94\"></script>\n<script data-kid=\"95\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  gsap.utils.toArray('.reveal').forEach((el, i) => {\n    gsap.from(el, {\n      scrollTrigger: {\n        trigger: el,\n        start: 'top 85%',\n        toggleActions: 'play none none none'\n      },\n      opacity: 0,\n      y: 40,\n      duration: 1,\n      ease: 'power3.out',\n      delay: i * 0.1\n    });\n  });\n\n  // Animate flame bars on hover/scroll\n  gsap.from('.flame-bar', {\n    scrollTrigger: {\n      trigger: '.flamegraph-box',\n      start: 'top 80%'\n    },\n    scaleX: 0,\n    transformOrigin: 'left center',\n    stagger: 0.15,\n    duration: 1.5,\n    ease: 'expo.out'\n  });\n</script>",
      "comments": [],
      "created": "2026-06-22T02:53:46.236192+00:00",
      "modified": "2026-06-22T02:54:08.081322+00:00",
      "id": "var_358413c31f8e"
    },
    "var_c522645f4301": {
      "type": "variant",
      "label": "VantaDB - Definitive Landing (Anti-Slop)",
      "parentId": "var_70b25bfbeb66",
      "themeId": null,
      "rect": {
        "x": 7700,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600&family=Outfit:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --void: #050507;\n    --surface: #0f1014;\n    --raised: #16181d;\n    --amber: #ff6a00;\n    --steel: #8b9eb7;\n    --foreground: #f7f5f2;\n    --border: #22252b;\n    --success: #28c840;\n    --warn: #febc2e;\n    \n    --font-display: 'Space Grotesk', sans-serif;\n    --font-body: 'Outfit', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--void);\n    color: var(--foreground);\n    font-family: var(--font-body);\n    margin: 0;\n    overflow-x: clip;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  /* --- ANTI-SLOP HUD --- */\n  .hud-frame {\n    position: fixed;\n    inset: 20px;\n    border: 1px solid var(--border);\n    pointer-events: none;\n    z-index: 9999;\n    opacity: 0.4;\n  }\n  .hud-corner {\n    position: absolute;\n    width: 30px;\n    height: 30px;\n    border: 2px solid var(--amber);\n  }\n  .hc-tl { top: -2px; left: -2px; border-right: none; border-bottom: none; }\n  .hc-tr { top: -2px; right: -2px; border-left: none; border-bottom: none; }\n  .hc-bl { bottom: -2px; left: -2px; border-right: none; border-top: none; }\n  .hc-br { bottom: -2px; right: -2px; border-left: none; border-top: none; }\n  \n  .hud-stats {\n    position: absolute;\n    bottom: 40px;\n    right: 40px;\n    font-family: var(--font-mono);\n    font-size: 10px;\n    color: var(--amber);\n    display: flex;\n    flex-direction: column;\n    align-items: flex-end;\n    gap: 4px;\n    pointer-events: none;\n  }\n\n  /* Scanlines & Grain */\n  .vanta-overlay {\n    position: fixed;\n    inset: 0;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n    opacity: 0.05;\n    pointer-events: none;\n    z-index: 100;\n  }\n\n  /* Typography Refinement */\n  .text-display { font-family: var(--font-display); font-size: clamp(4rem, 8vw, 7.5rem); line-height: 0.95; letter-spacing: -0.04em; }\n  .text-headline { font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.035em; }\n  .text-label { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--steel); }\n  .mono-sharp { font-family: var(--font-mono); -webkit-font-smoothing: initial; font-feature-settings: \"tnum\"; }\n\n  /* Navigation */\n  nav {\n    position: fixed;\n    top: 0;\n    width: 100%;\n    height: 72px;\n    background: rgba(5, 5, 7, 0.9);\n    backdrop-filter: blur(20px);\n    border-bottom: 1px solid var(--border);\n    z-index: 1000;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 0 60px;\n  }\n  .nav-links { display: flex; gap: 40px; }\n  .nav-link { text-decoration: none; transition: 0.3s; position: relative; padding: 4px 0; }\n  .nav-link::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 1px; background: var(--amber); transition: 0.3s; }\n  .nav-link:hover::after { width: 100%; }\n  .nav-link:hover { color: var(--amber); }\n\n  /* Hero */\n  .hero {\n    height: 100vh;\n    display: flex;\n    align-items: center;\n    position: relative;\n    padding: 0 10%;\n    overflow: hidden;\n  }\n  .hero-video {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    opacity: 0.3;\n    z-index: -1;\n    filter: saturate(0) contrast(1.2);\n  }\n  .hero-cursor {\n    display: inline-block;\n    width: 0.5em;\n    height: 1em;\n    background: var(--amber);\n    margin-left: 12px;\n    vertical-align: middle;\n    box-shadow: 0 0 20px var(--amber);\n    animation: blink 0.8s step-end infinite;\n  }\n  @keyframes blink { 50% { opacity: 0; } }\n\n  .btn-primary {\n    background: var(--amber);\n    color: #000;\n    padding: 16px 40px;\n    border-radius: 999px;\n    font-family: var(--font-mono);\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    border: none;\n    cursor: pointer;\n    box-shadow: 0 0 0 0 rgba(255,106,0,0);\n    transition: 0.3s;\n  }\n  .btn-primary:hover {\n    box-shadow: 0 0 30px rgba(255,106,0,0.4);\n    transform: translateY(-2px);\n  }\n\n  /* Comparison Section */\n  .cmp-section { padding: 120px 10%; background: var(--surface); border-top: 1px solid var(--border); }\n  .cmp-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n    gap: 1px;\n    background: var(--border);\n    border: 1px solid var(--border);\n    margin-top: 60px;\n  }\n  .cmp-card {\n    background: var(--void);\n    padding: 40px;\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n    transition: 0.3s;\n  }\n  .cmp-card:hover { background: var(--surface); }\n  .cmp-label { color: var(--amber); font-family: var(--font-mono); font-size: 12px; }\n  .cmp-row { display: flex; justify-content: space-between; align-items: baseline; }\n  .cmp-val { font-size: 1.5rem; font-family: var(--font-display); }\n  .cmp-badge { padding: 4px 10px; border-radius: 4px; font-size: 10px; font-family: var(--font-mono); }\n  .badge-legacy { background: rgba(255,0,0,0.1); color: #ff5f56; border: 1px solid #ff5f5633; }\n  .badge-vanta { background: rgba(40,200,64,0.1); color: var(--success); border: 1px solid var(--success) 33; }\n\n  /* Interactive Quickstart */\n  .qs-section { padding: 120px 10%; position: relative; }\n  .qs-container {\n    display: grid;\n    grid-template-columns: 280px 1fr;\n    gap: 60px;\n    margin-top: 80px;\n  }\n  .qs-nav { display: flex; flex-direction: column; gap: 8px; }\n  .qs-nav-btn {\n    text-align: left;\n    background: transparent;\n    border: 1px solid var(--border);\n    padding: 16px 20px;\n    border-radius: 8px;\n    color: var(--steel);\n    font-family: var(--font-mono);\n    cursor: pointer;\n    transition: 0.3s;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .qs-nav-btn.active { border-color: var(--amber); color: var(--foreground); background: var(--raised); }\n  .qs-nav-btn span { font-size: 10px; opacity: 0.5; }\n\n  .terminal-stepper {\n    background: var(--raised);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    overflow: hidden;\n    box-shadow: 0 40px 80px rgba(0,0,0,0.6);\n  }\n  .term-header { background: #1c1e24; padding: 12px 20px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid var(--border); }\n  .term-body { padding: 32px; font-family: var(--font-mono); font-size: 14px; min-height: 400px; line-height: 1.6; }\n\n  /* Engine Scroller */\n  .scroller-section { padding: 100px 10%; display: grid; grid-template-columns: 1fr 1fr; gap: 100px; position: relative; }\n  .sticky-visual { position: sticky; top: 120px; height: calc(100vh - 240px); display: flex; align-items: center; justify-content: center; }\n  .text-panels { padding: 100px 0; }\n  .panel-item { min-height: 60vh; display: flex; flex-direction: column; justify-content: center; padding: 120px 0; }\n\n  /* SVG Path Animations */\n  .anim-svg { width: 100%; height: auto; }\n  .draw-path { stroke-dasharray: 1000; stroke-dashoffset: 1000; transition: stroke-dashoffset 2s ease-out; }\n\n  /* Footer */\n  footer { padding: 120px 10% 60px; border-top: 1px solid var(--border); background: var(--void); }\n  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 80px; }\n\n  /* SLOP REMOVAL */\n  .no-slop { text-transform: none; }\n  h2 { position: relative; display: inline-block; }\n  \n</style>\n\n\n<div class=\"hud-frame\" data-kid=\"1\">\n  <div class=\"hud-corner hc-tl\" data-kid=\"2\"></div>\n  <div class=\"hud-corner hc-tr\" data-kid=\"3\"></div>\n  <div class=\"hud-corner hc-bl\" data-kid=\"4\"></div>\n  <div class=\"hud-corner hc-br\" data-kid=\"5\"></div>\n  <div class=\"hud-stats\" data-kid=\"6\">\n    <span class=\"mono-sharp\" data-kid=\"7\">PROCESS_ID: 0X8F21</span>\n    <span class=\"mono-sharp\" data-kid=\"8\">VERSION: 0.4.2_STABLE</span>\n    <span class=\"mono-sharp\" id=\"scroll-pct\" data-kid=\"9\">SCROLL: 00%</span>\n  </div>\n</div>\n\n<div class=\"vanta-overlay\" data-kid=\"10\"></div>\n<div class=\"scanlines\" style=\"position: fixed; inset: 0; background: linear-gradient(to bottom, transparent 50%, rgba(255,106,0,0.02) 50%); background-size: 100% 4px; pointer-events: none; z-index: 1000; opacity: 0.1;\" data-kid=\"11\"></div>\n\n<nav data-kid=\"12\">\n  <div class=\"text-label\" style=\"display: flex; align-items: center; gap: 12px; font-weight: 600; font-size: 1rem; color: var(--foreground);\" data-kid=\"13\">\n    <svg width=\"32\" height=\"32\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"14\">\n      <path d=\"M20 20 L50 80 L80 20\" stroke=\"var(--amber)\" stroke-width=\"8\" stroke-linecap=\"square\" data-kid=\"15\"></path>\n      <circle cx=\"50\" cy=\"50\" r=\"40\" stroke=\"var(--amber)\" stroke-width=\"2\" stroke-dasharray=\"4 8\" data-kid=\"16\"></circle>\n    </svg>\n    VANTADB\n  </div>\n  <div class=\"nav-links\" data-kid=\"17\">\n    <a href=\"#engine\" class=\"nav-link text-label\" data-kid=\"18\">Engine</a>\n    <a href=\"#architecture\" class=\"nav-link text-label\" data-kid=\"19\">Architecture</a>\n    <a href=\"#ecosystem\" class=\"nav-link text-label\" data-kid=\"20\">Ecosystem</a>\n    <a href=\"#\" class=\"nav-link text-label\" data-kid=\"21\">Docs</a>\n  </div>\n  <button class=\"text-label\" style=\"background: transparent; border: 1px solid var(--amber); color: var(--amber); padding: 8px 20px; border-radius: 999px; cursor: pointer;\" data-kid=\"22\">GitHub</button>\n</nav>\n\n\n<section class=\"hero\" data-kid=\"23\">\n  <video class=\"hero-video\" autoplay muted loop playsinline poster=\"https://images.pexels.com/videos/10296171/pexels-photo-10296171.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" data-kid=\"24\">\n    <source src=\"https://videos.pexels.com/video-files/10296171/10296171-hd_1920_1080_25fps.mp4\" type=\"video/mp4\" data-kid=\"25\">\n  </video>\n  <div style=\"max-width: 1000px; position: relative; z-index: 2;\" data-kid=\"26\">\n    <span class=\"text-label\" style=\"margin-bottom: 32px; display: block;\" data-kid=\"27\">// THE SINGULARITY ENGINE</span>\n    <h1 class=\"text-display scramble-text\" data-kid=\"28\">Memory that<br data-kid=\"29\">never escapes<span class=\"hero-cursor\" data-kid=\"30\"></span></h1>\n    <p class=\"text-steel\" style=\"font-size: 1.5rem; margin: 40px 0 64px; max-width: 700px; line-height: 1.5;\" data-kid=\"31\">\n      Embedded Rust engine for AI agents. Hybrid search, GraphRAG, and crash-safe durability in a <span style=\"color: var(--foreground);\" data-kid=\"32\">single binary.</span>\n    </p>\n    <div style=\"display: flex; gap: 40px; align-items: center;\" data-kid=\"33\">\n      <button class=\"btn-primary\" id=\"pip-btn\" data-kid=\"34\">pip install vantadb-py</button>\n      <a href=\"#\" class=\"text-label\" style=\"color: var(--amber); text-decoration: none;\" data-kid=\"35\">Explore Architecture →</a>\n    </div>\n  </div>\n</section>\n\n\n<section style=\"background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); display: flex;\" data-kid=\"36\">\n  <div style=\"flex: 1; padding: 40px; border-right: 1px solid var(--border); text-align: center;\" data-kid=\"37\">\n    <div class=\"text-label\" style=\"margin-bottom: 12px;\" data-kid=\"38\">P99 LATENCY</div>\n    <div class=\"text-headline\" style=\"font-size: 3.5rem; color: var(--amber);\" data-kid=\"39\">1.2ms</div>\n  </div>\n  <div style=\"flex: 1; padding: 40px; border-right: 1px solid var(--border); text-align: center;\" data-kid=\"40\">\n    <div class=\"text-label\" style=\"margin-bottom: 12px;\" data-kid=\"41\">MAX VECTOR DIMS</div>\n    <div class=\"text-headline\" style=\"font-size: 3.5rem;\" data-kid=\"42\">32K</div>\n  </div>\n  <div style=\"flex: 1; padding: 40px; border-right: 1px solid var(--border); text-align: center;\" data-kid=\"43\">\n    <div class=\"text-label\" style=\"margin-bottom: 12px;\" data-kid=\"44\">RECALL ACCURACY</div>\n    <div class=\"text-headline\" style=\"font-size: 3.5rem;\" data-kid=\"45\">100%</div>\n  </div>\n  <div style=\"flex: 1; padding: 40px; text-align: center;\" data-kid=\"46\">\n    <div class=\"text-label\" style=\"margin-bottom: 12px;\" data-kid=\"47\">EXTERNAL DEPS</div>\n    <div class=\"text-headline\" style=\"font-size: 3.5rem; opacity: 0.3;\" data-kid=\"48\">0</div>\n  </div>\n</section>\n\n\n<section class=\"cmp-section\" data-kid=\"49\">\n  <span class=\"text-label\" data-kid=\"50\">// VantaDB vs. Legacy Stack</span>\n  <h2 class=\"text-headline scramble-text\" style=\"margin: 24px 0 0;\" data-kid=\"51\">Stop assembling,<br data-kid=\"52\">start building.</h2>\n  \n  <div class=\"cmp-grid\" data-kid=\"53\">\n    <div class=\"cmp-card\" data-kid=\"54\">\n      <span class=\"cmp-label\" data-kid=\"55\">STORAGE</span>\n      <div class=\"cmp-row\" data-kid=\"56\"><span class=\"cmp-val\" data-kid=\"57\">Pinecone + Redis + S3</span> <span class=\"cmp-badge badge-legacy\" data-kid=\"58\">3 DEPS</span></div>\n      <div style=\"height: 1px; background: var(--border);\" data-kid=\"59\"></div>\n      <div class=\"cmp-row\" data-kid=\"60\"><span class=\"cmp-val\" style=\"color: var(--amber);\" data-kid=\"61\">pip install vantadb</span> <span class=\"cmp-badge badge-vanta\" data-kid=\"62\">1 CMD</span></div>\n    </div>\n    <div class=\"cmp-card\" data-kid=\"63\">\n      <span class=\"cmp-label\" data-kid=\"64\">LATENCY</span>\n      <div class=\"cmp-row\" data-kid=\"65\"><span class=\"cmp-val\" data-kid=\"66\">200ms (Network)</span> <span class=\"cmp-badge badge-legacy\" data-kid=\"67\">SLOW</span></div>\n      <div style=\"height: 1px; background: var(--border);\" data-kid=\"68\"></div>\n      <div class=\"cmp-row\" data-kid=\"69\"><span class=\"cmp-val\" style=\"color: var(--amber);\" data-kid=\"70\">1.2ms (In-Process)</span> <span class=\"cmp-badge badge-vanta\" data-kid=\"71\">FAST</span></div>\n    </div>\n    <div class=\"cmp-card\" data-kid=\"72\">\n      <span class=\"cmp-label\" data-kid=\"73\">MAINTENANCE</span>\n      <div class=\"cmp-row\" data-kid=\"74\"><span class=\"cmp-val\" data-kid=\"75\">3 Managed Services</span> <span class=\"cmp-badge badge-legacy\" data-kid=\"76\">HIGH</span></div>\n      <div style=\"height: 1px; background: var(--border);\" data-kid=\"77\"></div>\n      <div class=\"cmp-row\" data-kid=\"78\"><span class=\"cmp-val\" style=\"color: var(--amber);\" data-kid=\"79\">0 Daemon Processes</span> <span class=\"cmp-badge badge-vanta\" data-kid=\"80\">ZERO</span></div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"qs-section\" data-kid=\"81\">\n  <span class=\"text-label\" data-kid=\"82\">// Integration</span>\n  <h2 class=\"text-headline scramble-text\" style=\"margin-top: 16px;\" data-kid=\"83\">One binary, one line.</h2>\n  \n  <div class=\"qs-container\" data-kid=\"84\">\n    <div class=\"qs-nav\" data-kid=\"85\">\n      <button class=\"qs-nav-btn active\" onclick=\"switchStep(0)\" data-kid=\"86\"><span data-kid=\"87\">01</span> INSTALL</button>\n      <button class=\"qs-nav-btn\" onclick=\"switchStep(1)\" data-kid=\"88\"><span data-kid=\"89\">02</span> INITIALIZE</button>\n      <button class=\"qs-nav-btn\" onclick=\"switchStep(2)\" data-kid=\"90\"><span data-kid=\"91\">03</span> STORE</button>\n      <button class=\"qs-nav-btn\" onclick=\"switchStep(3)\" data-kid=\"92\"><span data-kid=\"93\">04</span> SEARCH</button>\n    </div>\n    \n    <div class=\"terminal-stepper\" data-kid=\"94\">\n      <div class=\"term-header\" data-kid=\"95\">\n        <div class=\"term-dot\" style=\"background: #ff5f56;\" data-kid=\"96\"></div>\n        <div class=\"term-dot\" style=\"background: #ffbd2e;\" data-kid=\"97\"></div>\n        <div class=\"term-dot\" style=\"background: #27c93f;\" data-kid=\"98\"></div>\n        <span class=\"text-label\" style=\"margin-left: auto; opacity: 0.5;\" data-kid=\"99\">vantadb_shell — v0.1</span>\n      </div>\n      <div class=\"term-body\" id=\"qs-terminal\" data-kid=\"100\">\n        <div style=\"color: var(--steel);\" data-kid=\"101\">$ pip install vantadb-py</div>\n        <div style=\"color: var(--success); margin-top: 12px;\" data-kid=\"102\">✓ Successfully installed vantadb-py-0.4.2</div>\n        <div style=\"color: var(--steel);\" data-kid=\"103\">✓ Pure Rust core dependencies analyzed</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"scroller-section\" id=\"engine\" data-kid=\"104\">\n  <div class=\"text-panels\" data-kid=\"105\">\n    <div class=\"panel-item\" id=\"trig-1\" data-kid=\"106\">\n      <span class=\"text-label text-amber\" data-kid=\"107\">01 // LEXICAL</span>\n      <h2 class=\"text-headline scramble-text\" data-kid=\"108\">BM25 Text Search</h2>\n      <p class=\"text-steel\" style=\"margin-top: 24px; font-size: 1.25rem;\" data-kid=\"109\">Full-text search at 1.2ms p99. No sidecars. The Rust engine embeds directly into your process.</p>\n    </div>\n    <div class=\"panel-item\" id=\"trig-2\" data-kid=\"110\">\n      <span class=\"text-label text-amber\" data-kid=\"111\">02 // VECTOR</span>\n      <h2 class=\"text-headline scramble-text\" data-kid=\"112\">HNSW Graph Index</h2>\n      <p class=\"text-steel\" style=\"margin-top: 24px; font-size: 1.25rem;\" data-kid=\"113\">Hierarchical Navigable Small World graphs for sub-ms recall across 32K dimensions.</p>\n    </div>\n    <div class=\"panel-item\" id=\"trig-3\" data-kid=\"114\">\n      <span class=\"text-label text-amber\" data-kid=\"115\">03 // GRAPH</span>\n      <h2 class=\"text-headline scramble-text\" data-kid=\"116\">GraphRAG Core</h2>\n      <p class=\"text-steel\" style=\"margin-top: 24px; font-size: 1.25rem;\" data-kid=\"117\">Weighted-edge graph relations with 0.2ms traversal. Multi-hop reasoning on a single WAL journal.</p>\n    </div>\n  </div>\n\n  <div class=\"sticky-visual\" data-kid=\"118\">\n    <div class=\"terminal-card\" style=\"width: 100%; max-width: 600px; height: 400px;\" data-kid=\"119\">\n       <div class=\"term-header\" data-kid=\"120\">\n         <span class=\"text-label\" data-kid=\"121\">ENGINE_STATE: ACTIVE</span>\n       </div>\n       <div class=\"term-body\" id=\"engine-code\" data-kid=\"122\">\n         <code style=\"color: #a3be8c;\" data-kid=\"123\">db.search(\"agent\", mode=\"bm25\")</code>\n         <div style=\"margin-top: 40px; opacity: 0.1;\" id=\"engine-icon\" data-kid=\"124\">\n           <i class=\"ti ti-binary\" style=\"font-size: 200px;\" data-kid=\"125\"></i>\n         </div>\n       </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"ffi-section\" id=\"architecture\" data-kid=\"126\">\n  <span class=\"text-label\" data-kid=\"127\">// Architecture</span>\n  <h2 class=\"text-headline scramble-text\" style=\"margin-top: 24px;\" data-kid=\"128\">Zero-copy FFI bridge.</h2>\n  \n  <div class=\"bridge-container\" data-kid=\"129\">\n    <div class=\"bridge-node\" data-kid=\"130\">\n      <i class=\"ti ti-brand-python\" style=\"font-size: 3rem; color: #3776ab;\" data-kid=\"131\"></i>\n      <div class=\"text-label\" style=\"margin-top: 16px;\" data-kid=\"132\">Python</div>\n    </div>\n    \n    <div style=\"flex: 1; padding: 0 40px;\" data-kid=\"133\">\n      <svg class=\"anim-svg\" viewBox=\"0 0 400 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"134\">\n        <path class=\"draw-path\" d=\"M0 50 H400\" stroke=\"var(--amber)\" stroke-width=\"2\" stroke-dasharray=\"10 10\" data-kid=\"135\"></path>\n        <circle class=\"ffi-packet\" cx=\"0\" cy=\"50\" r=\"4\" fill=\"var(--amber)\" data-kid=\"136\"></circle>\n        <circle class=\"ffi-packet\" cx=\"0\" cy=\"50\" r=\"4\" fill=\"var(--amber)\" style=\"animation-delay: 0.5s;\" data-kid=\"137\"></circle>\n      </svg>\n    </div>\n\n    <div class=\"bridge-node\" data-kid=\"138\">\n      <i class=\"ti ti-brand-rust\" style=\"font-size: 3rem; color: #dea584;\" data-kid=\"139\"></i>\n      <div class=\"text-label\" style=\"margin-top: 16px;\" data-kid=\"140\">Rust Core</div>\n    </div>\n  </div>\n</section>\n\n\n<section style=\"padding: 120px 10%;\" id=\"ecosystem\" data-kid=\"141\">\n  <span class=\"text-label\" data-kid=\"142\">// Ecosystem</span>\n  <h2 class=\"text-headline scramble-text\" style=\"margin-top: 24px;\" data-kid=\"143\">Drop-in for any framework.</h2>\n  <div style=\"margin-top: 64px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;\" data-kid=\"144\">\n    <div class=\"cmp-card\" style=\"border: 1px solid var(--border);\" data-kid=\"145\">\n      <i class=\"ti ti-box\" style=\"font-size: 2rem;\" data-kid=\"146\"></i>\n      <div class=\"text-label\" style=\"margin-top: 12px;\" data-kid=\"147\">LangChain</div>\n      <p class=\"text-steel\" data-kid=\"148\">Native VectorStore protocol.</p>\n    </div>\n    <div class=\"cmp-card\" style=\"border: 1px solid var(--border);\" data-kid=\"149\">\n      <i class=\"ti ti-route\" style=\"font-size: 2rem;\" data-kid=\"150\"></i>\n      <div class=\"text-label\" style=\"margin-top: 12px;\" data-kid=\"151\">LlamaIndex</div>\n      <p class=\"text-steel\" data-kid=\"152\">Recursive retrieval engine.</p>\n    </div>\n    <div class=\"cmp-card\" style=\"border: 1px solid var(--border);\" data-kid=\"153\">\n      <i class=\"ti ti-navigation\" style=\"font-size: 2rem;\" data-kid=\"154\"></i>\n      <div class=\"text-label\" style=\"margin-top: 12px;\" data-kid=\"155\">AutoGen</div>\n      <p class=\"text-steel\" data-kid=\"156\">Persistent memory store.</p>\n    </div>\n  </div>\n</section>\n\n\n<section style=\"padding: 160px 0; text-align: center; position: relative;\" data-kid=\"157\">\n  <div class=\"singularity\" data-kid=\"158\"></div>\n  <h2 class=\"text-display scramble-text\" data-kid=\"159\">Context that<br data-kid=\"160\"><span style=\"color: var(--amber);\" data-kid=\"161\">never fragments.</span></h2>\n  <button class=\"btn-primary\" style=\"margin-top: 64px;\" data-kid=\"162\">Get Started with VantaDB</button>\n</section>\n\n<footer data-kid=\"163\">\n  <div class=\"footer-grid\" data-kid=\"164\">\n    <div data-kid=\"165\">\n      <div class=\"text-label\" style=\"font-size: 1.5rem; color: var(--foreground); margin-bottom: 24px;\" data-kid=\"166\">VANTADB</div>\n      <p class=\"text-steel\" data-kid=\"167\">Embedded cognitive memory for AI agents. Open source and binary-efficient.</p>\n    </div>\n    <div data-kid=\"168\">\n      <h4 class=\"text-label\" data-kid=\"169\">Product</h4>\n      <ul class=\"footer-links\" data-kid=\"170\">\n        <li data-kid=\"171\"><a href=\"#\" data-kid=\"172\">Architecture</a></li>\n        <li data-kid=\"173\"><a href=\"#\" data-kid=\"174\">Latency Specs</a></li>\n        <li data-kid=\"175\"><a href=\"#\" data-kid=\"176\">Benchmarks</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"177\">\n      <h4 class=\"text-label\" data-kid=\"178\">Ecosystem</h4>\n      <ul class=\"footer-links\" data-kid=\"179\">\n        <li data-kid=\"180\"><a href=\"#\" data-kid=\"181\">Integrations</a></li>\n        <li data-kid=\"182\"><a href=\"#\" data-kid=\"183\">GitHub</a></li>\n        <li data-kid=\"184\"><a href=\"#\" data-kid=\"185\">Documentation</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"186\">\n      <h4 class=\"text-label\" data-kid=\"187\">Resources</h4>\n      <ul class=\"footer-links\" data-kid=\"188\">\n        <li data-kid=\"189\"><a href=\"#\" data-kid=\"190\">Blog</a></li>\n        <li data-kid=\"191\"><a href=\"#\" data-kid=\"192\">Changelog</a></li>\n        <li data-kid=\"193\"><a href=\"#\" data-kid=\"194\">Discord</a></li>\n      </ul>\n    </div>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"195\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"196\"></script>\n<script data-kid=\"197\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // --- ANTI-SLOP ANIMATIONS ---\n\n  // 1. Text Scramble Effect\n  function scrambleText(element) {\n    const originalText = element.innerText;\n    const chars = \"!<>-_\\\\/[]{}—=+*^?#________\";\n    let iterations = 0;\n    \n    const interval = setInterval(() => {\n      element.innerText = originalText\n        .split(\"\")\n        .map((char, index) => {\n          if (index < iterations) return originalText[index];\n          return chars[Math.floor(Math.random() * chars.length)];\n        })\n        .join(\"\");\n      \n      if (iterations >= originalText.length) clearInterval(interval);\n      iterations += 1 / 3;\n    }, 30);\n  }\n\n  gsap.utils.toArray('.scramble-text').forEach(h2 => {\n    ScrollTrigger.create({\n      trigger: h2,\n      start: 'top 85%',\n      onEnter: () => scrambleText(h2)\n    });\n  });\n\n  // 2. HUD Reaction to Scroll\n  window.addEventListener('scroll', () => {\n    const pct = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);\n    document.getElementById('scroll-pct').innerText = `SCROLL: ${pct.toString().padStart(2, '0')}%`;\n    \n    gsap.to('.hud-frame', {\n      opacity: 0.2 + (pct / 200),\n      duration: 0.3\n    });\n  });\n\n  // 3. SVG Path Drawing (FFI Bridge)\n  gsap.from('.draw-path', {\n    scrollTrigger: {\n      trigger: '.ffi-section',\n      start: 'top 70%'\n    },\n    strokeDashoffset: 0,\n    duration: 3,\n    ease: 'power2.inOut'\n  });\n\n  gsap.to('.ffi-packet', {\n    motionPath: {\n      path: \".draw-path\",\n      align: \".draw-path\"\n    },\n    duration: 2,\n    repeat: -1,\n    ease: \"none\"\n  });\n\n  // 4. Magnetic Button\n  const btn = document.querySelector('#pip-btn');\n  const xTo = gsap.quickTo(btn, \"x\", {duration: 0.4, ease: \"power3\"});\n  const yTo = gsap.quickTo(btn, \"y\", {duration: 0.4, ease: \"power3\"});\n\n  window.addEventListener(\"mousemove\", e => {\n    const rect = btn.getBoundingClientRect();\n    const bx = rect.left + rect.width / 2;\n    const by = rect.top + rect.height / 2;\n    const dist = Math.sqrt(Math.pow(e.clientX - bx, 2) + Math.pow(e.clientY - by, 2));\n\n    if (dist < 200) {\n      xTo((e.clientX - bx) * 0.25);\n      yTo((e.clientY - by) * 0.25);\n    } else {\n      xTo(0); yTo(0);\n    }\n  });\n\n  // Quickstart Steps Logic\n  const qsSteps = [\n    { cmd: \"$ pip install vantadb-py\", out: \"✓ Successfully installed vantadb-py-0.4.2<br>✓ Pure Rust core dependencies analyzed\" },\n    { cmd: \"import vantadb_py as vanta<br>db = vanta.VantaDB('./memory')\", out: \"✓ Folder path validated<br>✓ WAL recovery completed in 0.2ms\" },\n    { cmd: \"db.put('memories', 'k-1', 'Agent data...', ...)\", out: \"✓ CRC32C verified: 0x92f3a1d4<br>✓ WAL sync succeeded\" },\n    { cmd: \"hits = db.search_memory('memories', ...)\", out: \"🔍 Executing hybrid plan: BM25 + HNSW<br>→ Latency: 1.2ms (Local FFI)\" }\n  ];\n\n  function switchStep(idx) {\n    document.querySelectorAll('.qs-nav-btn').forEach((b, i) => b.classList.toggle('active', i === idx));\n    const term = document.getElementById('qs-terminal');\n    gsap.to(term, { opacity: 0, y: 10, duration: 0.2, onComplete: () => {\n      term.innerHTML = `<div style=\"color: var(--steel);\">${qsSteps[idx].cmd}</div><div style=\"color: var(--success); margin-top: 12px;\">${qsSteps[idx].out}</div>`;\n      gsap.to(term, { opacity: 1, y: 0, duration: 0.4 });\n    }});\n  }\n\n  // Engine Scroller\n  const engineContent = [\n    { code: 'db.search(\"agent\", mode=\"bm25\")', icon: 'ti-binary' },\n    { code: 'db.query_vectors(vec, limit=10)', icon: 'ti-mesh' },\n    { code: 'db.traverse(\"doc_1\", depth=3)', icon: 'ti-git-branch' }\n  ];\n\n  function updateEngine(idx) {\n    const code = document.querySelector('#engine-code code');\n    const icon = document.querySelector('#engine-icon i');\n    gsap.to([code, icon], { opacity: 0, duration: 0.2, onComplete: () => {\n      code.innerText = engineContent[idx].code;\n      icon.className = `ti ${engineContent[idx].icon}`;\n      gsap.to([code, icon], { opacity: 1, duration: 0.4 });\n    }});\n  }\n\n  ScrollTrigger.create({ trigger: '#trig-1', start: 'top center', onEnter: () => updateEngine(0), onEnterBack: () => updateEngine(0) });\n  ScrollTrigger.create({ trigger: '#trig-2', start: 'top center', onEnter: () => updateEngine(1), onEnterBack: () => updateEngine(1) });\n  ScrollTrigger.create({ trigger: '#trig-3', start: 'top center', onEnter: () => updateEngine(2), onEnterBack: () => updateEngine(2) });\n\n</script>",
