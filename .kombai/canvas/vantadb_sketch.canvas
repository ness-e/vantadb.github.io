    },
    "var_bf53a61ac086": {
      "type": "variant",
      "label": "Subpage: Latency",
      "parentId": "var_70b25bfbeb66",
      "themeId": null,
      "rect": {
        "x": 6160,
        "y": 0,
        "w": 1440,
        "h": 800
