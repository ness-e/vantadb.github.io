      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600&family=Outfit:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap');\n\n  :root {\n    --void: #050507;\n    --surface: #0f1014;\n    --raised: #16181d;\n    --amber: #ff6a00;\n    --amber-dim: rgba(255, 106, 0, 0.12);\n    --steel: #8b9eb7;\n    --foreground: #f7f5f2;\n    --border: #22252b;\n    --danger: #e53935;\n    --font-display: 'Space Grotesk', sans-serif;\n    --font-body: 'Outfit', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--void);\n    color: var(--foreground);\n    font-family: var(--font-body);\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n  }\n\n  .container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 40px;\n  }\n\n  /* --- Hero --- */\n  .hero-latency {\n    padding: 160px 0 100px;\n    text-align: center;\n    position: relative;\n    border-bottom: 1px solid var(--border);\n  }\n\n  .mono-label {\n    font-family: var(--font-mono);\n    font-size: 0.72rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--steel);\n    display: block;\n    margin-bottom: 24px;\n  }\n\n  .display-title {\n    font-family: var(--font-display);\n    font-size: clamp(3.5rem, 7vw, 5.5rem);\n    line-height: 1;\n    letter-spacing: -0.035em;\n    margin-bottom: 32px;\n  }\n\n  .text-highlight {\n    color: var(--amber);\n  }\n\n  .hero-desc {\n    font-size: 1.25rem;\n    color: var(--steel);\n    max-width: 600px;\n    margin: 0 auto 64px;\n    line-height: 1.6;\n  }\n\n  /* --- Quick Stats --- */\n  .stats-row {\n    display: flex;\n    justify-content: center;\n    gap: 80px;\n    margin-bottom: 40px;\n  }\n\n  .stat-item {\n    text-align: center;\n  }\n\n  .stat-val {\n    font-family: var(--font-display);\n    font-size: 3.5rem;\n    display: block;\n    line-height: 1;\n  }\n\n  .stat-lab {\n    font-family: var(--font-mono);\n    font-size: 0.65rem;\n    color: var(--steel);\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    margin-top: 8px;\n    display: block;\n  }\n\n  /* --- Comparison Section --- */\n  .comp-section {\n    padding: 100px 0;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 80px;\n  }\n\n  .comp-card {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    padding: 40px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .comp-card.vanta {\n    border-color: rgba(255, 106, 0, 0.2);\n    background: linear-gradient(135deg, var(--surface), var(--amber-dim));\n  }\n\n  .comp-title {\n    font-family: var(--font-display);\n    font-size: 2rem;\n    margin-bottom: 32px;\n  }\n\n  .comp-list {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n  }\n\n  .comp-list li {\n    display: flex;\n    gap: 16px;\n    font-size: 1.05rem;\n    color: var(--steel);\n    align-items: flex-start;\n  }\n\n  .icon-box {\n    width: 20px;\n    height: 20px;\n    flex-shrink: 0;\n    margin-top: 3px;\n  }\n\n  .icon-check { color: var(--amber); }\n  .icon-cross { color: #555; }\n\n  /* --- Calculator --- */\n  .calc-section {\n    padding: 120px 0;\n    background: var(--raised);\n    border-top: 1px solid var(--border);\n    border-bottom: 1px solid var(--border);\n    text-align: center;\n  }\n\n  .calc-container {\n    max-width: 800px;\n    margin: 0 auto;\n  }\n\n  .slider-wrapper {\n    margin: 64px 0;\n    position: relative;\n  }\n\n  .slider-labels {\n    display: flex;\n    justify-content: space-between;\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--steel);\n    margin-bottom: 16px;\n  }\n\n  input[type=range] {\n    -webkit-appearance: none;\n    width: 100%;\n    background: var(--border);\n    height: 4px;\n    border-radius: 2px;\n    outline: none;\n  }\n\n  input[type=range]::-webkit-slider-thumb {\n    -webkit-appearance: none;\n    width: 24px;\n    height: 24px;\n    background: var(--amber);\n    border: 4px solid var(--void);\n    border-radius: 50%;\n    cursor: pointer;\n    box-shadow: 0 0 15px rgba(255, 106, 0, 0.4);\n  }\n\n  .result-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 32px;\n  }\n\n  .result-card {\n    padding: 40px;\n    border-radius: 12px;\n    background: var(--surface);\n    border: 1px solid var(--border);\n    text-align: left;\n  }\n\n  .result-card.vanta {\n    border-color: var(--amber);\n  }\n\n  .result-val {\n    font-family: var(--font-display);\n    font-size: 3rem;\n    line-height: 1;\n    margin: 12px 0;\n  }\n\n  .multiplier {\n    margin-top: 48px;\n    font-family: var(--font-display);\n    font-size: 1.5rem;\n    color: var(--amber);\n    font-weight: 600;\n  }\n\n  /* --- Bar Chart --- */\n  .breakdown-section {\n    padding: 120px 0;\n  }\n\n  .bars-container {\n    max-width: 700px;\n    margin: 64px auto 0;\n    display: flex;\n    flex-direction: column;\n    gap: 32px;\n  }\n\n  .bar-row {\n    display: grid;\n    grid-template-columns: 120px 1fr 100px;\n    gap: 24px;\n    align-items: center;\n  }\n\n  .bar-label {\n    font-family: var(--font-mono);\n    font-size: 0.72rem;\n    color: var(--steel);\n    text-transform: uppercase;\n  }\n\n  .bar-visual {\n    height: 12px;\n    background: var(--border);\n    border-radius: 6px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .bar-fill {\n    height: 100%;\n    position: absolute;\n    left: 0;\n    top: 0;\n    border-radius: 6px;\n  }\n\n  .bar-legacy {\n    background: #333;\n    z-index: 1;\n  }\n\n  .bar-vanta {\n    background: var(--amber);\n    z-index: 2;\n  }\n\n  .bar-value {\n    font-family: var(--font-mono);\n    font-size: 0.8rem;\n    text-align: right;\n  }\n\n  .legend {\n    display: flex;\n    justify-content: center;\n    gap: 32px;\n    margin-top: 48px;\n  }\n\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--steel);\n  }\n\n  .legend-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n  }\n\n  /* --- Nav --- */\n  .top-nav {\n    height: 64px;\n    display: flex;\n    align-items: center;\n    border-bottom: 1px solid var(--border);\n    background: var(--void);\n    position: sticky;\n    top: 0;\n    z-index: 100;\n  }\n\n  .back-link {\n    font-family: var(--font-mono);\n    font-size: 0.72rem;\n    color: var(--steel);\n    text-decoration: none;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .back-link:hover {\n    color: var(--amber);\n  }\n</style>\n\n<nav class=\"top-nav\" data-kid=\"1\">\n  <div class=\"container\" data-kid=\"2\">\n    <a href=\"#\" class=\"back-link\" data-kid=\"3\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" data-kid=\"4\"><path d=\"M19 12H5m7 7l-7-7 7-7\" data-kid=\"5\"></path></svg>\n      Back to main\n    </a>\n  </div>\n</nav>\n\n<section class=\"hero-latency\" data-kid=\"6\">\n  <div class=\"container\" data-kid=\"7\">\n    <span class=\"mono-label\" data-kid=\"8\">// Latency Performance</span>\n    <h1 class=\"display-title\" data-kid=\"9\">1.2ms p50.<br data-kid=\"10\"><span class=\"text-highlight\" data-kid=\"11\">No network.</span></h1>\n    <p class=\"hero-desc\" data-kid=\"12\">VantaDB runs in your process — no network round-trip, no serialization overhead, no cold starts. Every microsecond matters when your agent is waiting.</p>\n    \n    <div class=\"stats-row\" data-kid=\"13\">\n      <div class=\"stat-item\" data-kid=\"14\">\n        <span class=\"stat-val\" data-kid=\"15\">1.2ms</span>\n        <span class=\"stat-lab\" data-kid=\"16\">VantaDB p50</span>\n      </div>\n      <div class=\"stat-item\" data-kid=\"17\">\n        <span class=\"stat-val\" style=\"color: #444;\" data-kid=\"18\">200ms</span>\n        <span class=\"stat-lab\" data-kid=\"19\">Legacy p50</span>\n      </div>\n      <div class=\"stat-item\" data-kid=\"20\">\n        <span class=\"stat-val text-highlight\" data-kid=\"21\">166×</span>\n        <span class=\"stat-lab\" data-kid=\"22\">Performance gain</span>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"container comp-section\" data-kid=\"23\">\n  <div class=\"comp-card\" data-kid=\"24\">\n    <span class=\"mono-label\" style=\"color: var(--danger);\" data-kid=\"25\">// Legacy Path</span>\n    <h2 class=\"comp-title\" data-kid=\"26\">~200ms per query</h2>\n    <ul class=\"comp-list\" data-kid=\"27\">\n      <li data-kid=\"28\">\n        <svg class=\"icon-box icon-cross\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"29\"><path d=\"M18 6L6 18M6 6l12 12\" data-kid=\"30\"></path></svg>\n        <span data-kid=\"31\">Network round-trip: 50-80ms (TLS + serialization)</span>\n      </li>\n      <li data-kid=\"32\">\n        <svg class=\"icon-box icon-cross\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"33\"><path d=\"M18 6L6 18M6 6l12 12\" data-kid=\"34\"></path></svg>\n        <span data-kid=\"35\">Remote index traversal: 40-60ms</span>\n      </li>\n      <li data-kid=\"36\">\n        <svg class=\"icon-box icon-cross\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"37\"><path d=\"M18 6L6 18M6 6l12 12\" data-kid=\"38\"></path></svg>\n        <span data-kid=\"39\">Result serialization: 20-30ms</span>\n      </li>\n      <li data-kid=\"40\">\n        <svg class=\"icon-box icon-cross\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"41\"><path d=\"M18 6L6 18M6 6l12 12\" data-kid=\"42\"></path></svg>\n        <span data-kid=\"43\">Cache miss penalty: 100ms+ to S3 fallback</span>\n      </li>\n    </ul>\n  </div>\n  \n  <div class=\"comp-card vanta\" data-kid=\"44\">\n    <span class=\"mono-label text-highlight\" data-kid=\"45\">// VantaDB Path</span>\n    <h2 class=\"comp-title\" data-kid=\"46\">1.2ms in-process</h2>\n    <ul class=\"comp-list\" data-kid=\"47\">\n      <li data-kid=\"48\">\n        <svg class=\"icon-box icon-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"49\"><path d=\"M20 6L9 17l-5-5\" data-kid=\"50\"></path></svg>\n        <span style=\"color: var(--foreground);\" data-kid=\"51\">Zero network: same-process memory access</span>\n      </li>\n      <li data-kid=\"52\">\n        <svg class=\"icon-box icon-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"53\"><path d=\"M20 6L9 17l-5-5\" data-kid=\"54\"></path></svg>\n        <span style=\"color: var(--foreground);\" data-kid=\"55\">HNSW graph traversal: 0.4-0.8ms</span>\n      </li>\n      <li data-kid=\"56\">\n        <svg class=\"icon-box icon-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"57\"><path d=\"M20 6L9 17l-5-5\" data-kid=\"58\"></path></svg>\n        <span style=\"color: var(--foreground);\" data-kid=\"59\">BM25 intersection: 0.2-0.4ms</span>\n      </li>\n      <li data-kid=\"60\">\n        <svg class=\"icon-box icon-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" data-kid=\"61\"><path d=\"M20 6L9 17l-5-5\" data-kid=\"62\"></path></svg>\n        <span style=\"color: var(--foreground);\" data-kid=\"63\">No cold start: process is always warm</span>\n      </li>\n    </ul>\n  </div>\n</section>\n\n<section class=\"calc-section\" data-kid=\"64\">\n  <div class=\"container calc-container\" data-kid=\"65\">\n    <span class=\"mono-label\" data-kid=\"66\">// Pipeline Latency</span>\n    <h2 class=\"comp-title\" style=\"font-size: 2.5rem; margin-bottom: 16px;\" data-kid=\"67\">Multi-query impact</h2>\n    <p style=\"color: var(--steel);\" data-kid=\"68\">Agents often perform serial queries for reasoning. Watch the latency compound.</p>\n    \n    <div class=\"slider-wrapper\" data-kid=\"69\">\n      <div class=\"slider-labels\" data-kid=\"70\">\n        <span data-kid=\"71\">Queries in pipeline: <span id=\"q-count\" style=\"color: var(--foreground);\" data-kid=\"72\">50</span></span>\n        <span data-kid=\"73\">Drag to adjust</span>\n      </div>\n      <input type=\"range\" id=\"q-slider\" min=\"1\" max=\"200\" value=\"50\" data-kid=\"74\">\n    </div>\n    \n    <div class=\"result-grid\" data-kid=\"75\">\n      <div class=\"result-card\" data-kid=\"76\">\n        <span class=\"mono-label\" data-kid=\"77\">Legacy Cloud DB</span>\n        <div class=\"result-val\" id=\"legacy-total\" style=\"color: var(--danger);\" data-kid=\"78\">10.0s</div>\n        <span class=\"stat-lab\" data-kid=\"79\">~200ms per query</span>\n      </div>\n      <div class=\"result-card vanta\" data-kid=\"80\">\n        <span class=\"mono-label text-highlight\" data-kid=\"81\">VantaDB Embedded</span>\n        <div class=\"result-val\" id=\"vanta-total\" style=\"color: var(--amber);\" data-kid=\"82\">60ms</div>\n        <span class=\"stat-lab\" data-kid=\"83\">1.2ms per query</span>\n      </div>\n    </div>\n    \n    <div class=\"multiplier\" id=\"multiplier\" data-kid=\"84\">166× FASTER</div>\n  </div>\n</section>\n\n<section class=\"container breakdown-section\" data-kid=\"85\">\n  <div style=\"text-align: center;\" data-kid=\"86\">\n    <span class=\"mono-label\" data-kid=\"87\">// Per-query breakdown</span>\n    <h2 class=\"comp-title\" style=\"font-size: 2.5rem;\" data-kid=\"88\">Where the milliseconds go</h2>\n  </div>\n  \n  <div class=\"bars-container\" data-kid=\"89\">\n    \n    <div class=\"bar-row\" data-kid=\"90\">\n      <span class=\"bar-label\" data-kid=\"91\">Network</span>\n      <div class=\"bar-visual\" data-kid=\"92\">\n        <div class=\"bar-fill bar-legacy\" style=\"width: 85%;\" data-kid=\"93\"></div>\n        <div class=\"bar-fill bar-vanta\" style=\"width: 0%;\" data-kid=\"94\"></div>\n      </div>\n      <div class=\"bar-value\" data-kid=\"95\">\n        <div style=\"color: #666;\" data-kid=\"96\">75ms</div>\n        <div class=\"text-highlight\" data-kid=\"97\">0ms</div>\n      </div>\n    </div>\n    \n    \n    <div class=\"bar-row\" data-kid=\"98\">\n      <span class=\"bar-label\" data-kid=\"99\">Index Search</span>\n      <div class=\"bar-visual\" data-kid=\"100\">\n        <div class=\"bar-fill bar-legacy\" style=\"width: 60%;\" data-kid=\"101\"></div>\n        <div class=\"bar-fill bar-vanta\" style=\"width: 5%;\" data-kid=\"102\"></div>\n      </div>\n      <div class=\"bar-value\" data-kid=\"103\">\n        <div style=\"color: #666;\" data-kid=\"104\">50ms</div>\n        <div class=\"text-highlight\" data-kid=\"105\">0.6ms</div>\n      </div>\n    </div>\n    \n    \n    <div class=\"bar-row\" data-kid=\"106\">\n      <span class=\"bar-label\" data-kid=\"107\">Serialize</span>\n      <div class=\"bar-visual\" data-kid=\"108\">\n        <div class=\"bar-fill bar-legacy\" style=\"width: 30%;\" data-kid=\"109\"></div>\n        <div class=\"bar-fill bar-vanta\" style=\"width: 0%;\" data-kid=\"110\"></div>\n      </div>\n      <div class=\"bar-value\" data-kid=\"111\">\n        <div style=\"color: #666;\" data-kid=\"112\">25ms</div>\n        <div class=\"text-highlight\" data-kid=\"113\">0ms</div>\n      </div>\n    </div>\n    \n    \n    <div class=\"bar-row\" data-kid=\"114\">\n      <span class=\"bar-label\" data-kid=\"115\">Storage/WAL</span>\n      <div class=\"bar-visual\" data-kid=\"116\">\n        <div class=\"bar-fill bar-legacy\" style=\"width: 50%;\" data-kid=\"117\"></div>\n        <div class=\"bar-fill bar-vanta\" style=\"width: 5%;\" data-kid=\"118\"></div>\n      </div>\n      <div class=\"bar-value\" data-kid=\"119\">\n        <div style=\"color: #666;\" data-kid=\"120\">45ms</div>\n        <div class=\"text-highlight\" data-kid=\"121\">0.6ms</div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"legend\" data-kid=\"122\">\n    <div class=\"legend-item\" data-kid=\"123\">\n      <div class=\"legend-dot\" style=\"background: #333;\" data-kid=\"124\"></div>\n      Legacy Cloud Vector DB\n    </div>\n    <div class=\"legend-item\" data-kid=\"125\">\n      <div class=\"legend-dot\" style=\"background: var(--amber);\" data-kid=\"126\"></div>\n      VantaDB (In-Process)\n    </div>\n  </div>\n</section>\n\n<footer style=\"padding: 100px 0; text-align: center; border-top: 1px solid var(--border);\" data-kid=\"127\">\n  <div class=\"container\" data-kid=\"128\">\n    <span class=\"mono-label\" data-kid=\"129\">VantaDB — Rust Embedded Engine</span>\n    <h2 class=\"comp-title\" style=\"margin-top: 16px;\" data-kid=\"130\">Build contextually aware agents.</h2>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"131\"></script>\n<script data-kid=\"132\">\n  const slider = document.getElementById('q-slider');\n  const qCount = document.getElementById('q-count');\n  const legacyTotal = document.getElementById('legacy-total');\n  const vantaTotal = document.getElementById('vanta-total');\n  const multiplier = document.getElementById('multiplier');\n\n  function update() {\n    const val = parseInt(slider.value);\n    qCount.innerText = val;\n    \n    const legacyTime = val * 200; // 200ms\n    const vantaTime = val * 1.2; // 1.2ms\n    \n    legacyTotal.innerText = legacyTime >= 1000 ? (legacyTime/1000).toFixed(1) + 's' : legacyTime + 'ms';\n    vantaTotal.innerText = vantaTime >= 1000 ? (vantaTime/1000).toFixed(1) + 's' : Math.round(vantaTime) + 'ms';\n    \n    const mult = Math.round(legacyTime / vantaTime);\n    multiplier.innerText = mult + '× FASTER';\n  }\n\n  slider.addEventListener('input', update);\n  update();\n\n  // Subtle animations\n  gsap.from('.stat-item', {\n    y: 20,\n    opacity: 0,\n    stagger: 0.1,\n    duration: 1,\n    ease: 'power3.out'\n  });\n\n  gsap.from('.comp-card', {\n    scrollTrigger: {\n      trigger: '.comp-section',\n      start: 'top 80%'\n    },\n    y: 40,\n    opacity: 0,\n    stagger: 0.2,\n    duration: 1,\n    ease: 'power3.out'\n  });\n</script>",
