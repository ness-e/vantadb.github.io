      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600&family=Outfit:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --void: #050507;\n    --surface: #0f1014;\n    --raised: #16181d;\n    --amber: #ff6a00;\n    --amber-dim: rgba(255, 106, 0, 0.12);\n    --steel: #8b9eb7;\n    --foreground: #f7f5f2;\n    --border: #22252b;\n    --font-display: 'Space Grotesk', sans-serif;\n    --font-body: 'Outfit', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--void);\n    color: var(--foreground);\n    font-family: var(--font-body);\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n  }\n\n  .scanlines {\n    position: fixed;\n    inset: 0;\n    background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.05) 50%);\n    background-size: 100% 4px;\n    pointer-events: none;\n    z-index: 100;\n    opacity: 0.2;\n  }\n\n  .container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 40px;\n  }\n\n  /* Typography */\n  h1, h2, h3 {\n    font-family: var(--font-display);\n    letter-spacing: -0.035em;\n    margin: 0;\n    text-wrap: balance;\n  }\n\n  .mono-label {\n    font-family: var(--font-mono);\n    font-size: 0.72rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--steel);\n  }\n\n  /* Nav (Simplified for Subpage) */\n  nav {\n    height: 64px;\n    display: flex;\n    align-items: center;\n    position: fixed;\n    top: 0;\n    width: 100%;\n    z-index: 50;\n    background: rgba(5, 5, 7, 0.8);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid var(--border);\n  }\n\n  .nav-logo {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    font-family: var(--font-display);\n    font-weight: 600;\n    font-size: 1.1rem;\n    text-decoration: none;\n    color: var(--foreground);\n  }\n\n  /* Hero Subpage */\n  .hero-sub {\n    padding: 160px 0 80px;\n    border-bottom: 1px solid var(--border);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .hero-particles {\n    position: absolute;\n    inset: 0;\n    z-index: -1;\n    opacity: 0.3;\n  }\n\n  .hero-title {\n    font-size: clamp(3rem, 6vw, 4.5rem);\n    line-height: 1.1;\n    margin-bottom: 24px;\n  }\n\n  .hero-desc {\n    font-size: 1.25rem;\n    color: var(--steel);\n    max-width: 650px;\n    line-height: 1.6;\n  }\n\n  /* Use Cases Grid */\n  .uc-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 32px;\n    padding: 80px 0;\n  }\n\n  .term-window {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    overflow: hidden;\n    transition: transform 0.3s ease, border-color 0.3s ease;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .term-window:hover {\n    transform: translateY(-4px);\n    border-color: var(--amber);\n    box-shadow: 0 0 30px rgba(255, 106, 0, 0.05);\n  }\n\n  .term-header {\n    height: 36px;\n    background: #1c1e24;\n    display: flex;\n    align-items: center;\n    padding: 0 16px;\n    gap: 8px;\n    border-bottom: 1px solid var(--border);\n  }\n\n  .dot { width: 8px; height: 8px; border-radius: 50%; }\n  .dot-red { background: #ff5f56; }\n  .dot-yellow { background: #ffbd2e; }\n  .dot-green { background: #27c93f; }\n\n  .term-label {\n    margin-left: auto;\n    font-family: var(--font-mono);\n    font-size: 0.65rem;\n    color: var(--steel);\n    opacity: 0.6;\n  }\n\n  .term-body {\n    padding: 32px;\n    flex-grow: 1;\n  }\n\n  .uc-title {\n    font-size: 1.75rem;\n    margin-bottom: 16px;\n    color: var(--foreground);\n  }\n\n  .uc-desc {\n    font-size: 1rem;\n    color: var(--steel);\n    line-height: 1.6;\n    margin-bottom: 24px;\n  }\n\n  .tag-group {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n  }\n\n  .tag {\n    font-family: var(--font-mono);\n    font-size: 0.65rem;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    padding: 4px 10px;\n    background: var(--amber-dim);\n    color: var(--amber);\n    border-radius: 4px;\n    border: 1px solid rgba(255, 106, 0, 0.15);\n  }\n\n  /* Pipeline Section */\n  .pipeline-section {\n    padding: 100px 0;\n    background: var(--surface);\n    border-top: 1px solid var(--border);\n  }\n\n  .pipeline-header {\n    text-align: center;\n    margin-bottom: 80px;\n  }\n\n  .pipeline-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 40px;\n  }\n\n  .pipeline-item {\n    position: relative;\n    padding: 40px;\n    background: var(--raised);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n  }\n\n  .pipeline-step {\n    position: absolute;\n    top: -20px;\n    left: 40px;\n    background: var(--amber);\n    color: #000;\n    font-family: var(--font-mono);\n    font-weight: 600;\n    padding: 4px 12px;\n    border-radius: 4px;\n  }\n\n  .pipeline-title {\n    font-size: 1.5rem;\n    margin-bottom: 16px;\n  }\n\n  .pipeline-desc {\n    font-size: 0.95rem;\n    color: var(--steel);\n    line-height: 1.6;\n  }\n\n  /* Footer */\n  footer {\n    padding: 64px 0;\n    border-top: 1px solid var(--border);\n    text-align: center;\n  }\n</style>\n\n<div class=\"scanlines\" data-kid=\"1\"></div>\n\n<nav data-kid=\"2\">\n  <div class=\"container\" data-kid=\"3\">\n    <a href=\"#\" class=\"nav-logo\" data-kid=\"4\">\n      <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" data-kid=\"5\"><path d=\"M12 2L2 22h20L12 2zm0 4.5l6.5 13H5.5L12 6.5z\" fill=\"var(--amber)\" data-kid=\"6\"></path><circle cx=\"12\" cy=\"14\" r=\"2\" fill=\"var(--amber)\" data-kid=\"7\"></circle></svg>\n      VANTADB\n    </a>\n  </div>\n</nav>\n\n<section class=\"hero-sub\" data-kid=\"8\">\n  <video class=\"hero-particles\" src=\"https://videos.pexels.com/video-files/10296171/10296171-hd_1920_1080_25fps.mp4\" autoplay muted loop playsinline poster=\"https://images.pexels.com/videos/10296171/pexels-photo-10296171.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" data-kid=\"9\"></video>\n  <div class=\"container\" data-kid=\"10\">\n    <span class=\"mono-label\" style=\"display: block; margin-bottom: 16px;\" data-kid=\"11\">// PRODUCTION PATTERNS</span>\n    <h1 class=\"hero-title\" data-kid=\"12\">Built for agents<br data-kid=\"13\">that need context.</h1>\n    <p class=\"hero-desc\" data-kid=\"14\">Persistent memory, hybrid search, and GraphRAG. Eight production-tested patterns for embedding intelligence directly into your process.</p>\n  </div>\n</section>\n\n<div class=\"container\" data-kid=\"15\">\n  <section class=\"uc-grid\" data-kid=\"16\">\n    \n    <div class=\"term-window reveal\" data-kid=\"17\">\n      <div class=\"term-header\" data-kid=\"18\">\n        <div class=\"dot dot-red\" data-kid=\"19\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"20\"></div>\n        <div class=\"dot dot-green\" data-kid=\"21\"></div>\n        <span class=\"term-label\" data-kid=\"22\">memory.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"23\">\n        <h3 class=\"uc-title\" data-kid=\"24\">AI Agents Memory</h3>\n        <p class=\"uc-desc\" data-kid=\"25\">Persistent conversation history and agent thoughts. Context survives restarts with WAL crash safety — no external database required.</p>\n        <div class=\"tag-group\" data-kid=\"26\">\n          <span class=\"tag\" data-kid=\"27\">persistent</span>\n          <span class=\"tag\" data-kid=\"28\">≤1ms read</span>\n          <span class=\"tag\" data-kid=\"29\">crash-safe</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"term-window reveal\" data-kid=\"30\">\n      <div class=\"term-header\" data-kid=\"31\">\n        <div class=\"dot dot-red\" data-kid=\"32\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"33\"></div>\n        <div class=\"dot dot-green\" data-kid=\"34\"></div>\n        <span class=\"term-label\" data-kid=\"35\">search_engine.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"36\">\n        <h3 class=\"uc-title\" data-kid=\"37\">Local-First RAG</h3>\n        <p class=\"uc-desc\" data-kid=\"38\">Run BM25 lexical + HNSW vector fusion in-process. Full hybrid search without network overhead or separate infrastructure.</p>\n        <div class=\"tag-group\" data-kid=\"39\">\n          <span class=\"tag\" data-kid=\"40\">hybrid search</span>\n          <span class=\"tag\" data-kid=\"41\">zero deps</span>\n          <span class=\"tag\" data-kid=\"42\">on-device</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"term-window reveal\" data-kid=\"43\">\n      <div class=\"term-header\" data-kid=\"44\">\n        <div class=\"dot dot-red\" data-kid=\"45\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"46\"></div>\n        <div class=\"dot dot-green\" data-kid=\"47\"></div>\n        <span class=\"term-label\" data-kid=\"48\">code_intel.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"49\">\n        <h3 class=\"uc-title\" data-kid=\"50\">Codebase Intelligence</h3>\n        <p class=\"uc-desc\" data-kid=\"51\">Map function relations in a knowledge graph. Traverse graph hops with vector similarity for structural code retrieval.</p>\n        <div class=\"tag-group\" data-kid=\"52\">\n          <span class=\"tag\" data-kid=\"53\">GraphRAG</span>\n          <span class=\"tag\" data-kid=\"54\">AST-aware</span>\n          <span class=\"tag\" data-kid=\"55\">30K loc/s</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"term-window reveal\" data-kid=\"56\">\n      <div class=\"term-header\" data-kid=\"57\">\n        <div class=\"dot dot-red\" data-kid=\"58\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"59\"></div>\n        <div class=\"dot dot-green\" data-kid=\"60\"></div>\n        <span class=\"term-label\" data-kid=\"61\">multi_agent.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"62\">\n        <h3 class=\"uc-title\" data-kid=\"63\">Multi-Agent Orchestration</h3>\n        <p class=\"uc-desc\" data-kid=\"64\">Run independent agents on a single DB file. Namespace isolation prevents collisions while keeping a unified storage footprint.</p>\n        <div class=\"tag-group\" data-kid=\"65\">\n          <span class=\"tag\" data-kid=\"66\">namespaces</span>\n          <span class=\"tag\" data-kid=\"67\">isolation</span>\n          <span class=\"tag\" data-kid=\"68\">concurrent</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"term-window reveal\" data-kid=\"69\">\n      <div class=\"term-header\" data-kid=\"70\">\n        <div class=\"dot dot-red\" data-kid=\"71\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"72\"></div>\n        <div class=\"dot dot-green\" data-kid=\"73\"></div>\n        <span class=\"term-label\" data-kid=\"74\">commerce.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"75\">\n        <h3 class=\"uc-title\" data-kid=\"76\">E-Commerce Search</h3>\n        <p class=\"uc-desc\" data-kid=\"77\">Real-time product recommendations using vector behavior embeddings — updated instantly with zero reindexing lag.</p>\n        <div class=\"tag-group\" data-kid=\"78\">\n          <span class=\"tag\" data-kid=\"79\">vector</span>\n          <span class=\"tag\" data-kid=\"80\">metadata filter</span>\n          <span class=\"tag\" data-kid=\"81\">real-time</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"term-window reveal\" data-kid=\"82\">\n      <div class=\"term-header\" data-kid=\"83\">\n        <div class=\"dot dot-red\" data-kid=\"84\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"85\"></div>\n        <div class=\"dot dot-green\" data-kid=\"86\"></div>\n        <span class=\"term-label\" data-kid=\"87\">edge_iot.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"88\">\n        <h3 class=\"uc-title\" data-kid=\"89\">Edge / IoT Inference</h3>\n        <p class=\"uc-desc\" data-kid=\"90\">Persist device state on embedded hardware. Sub-millisecond reads with CRC32C WAL protection on ARM and RISC-V.</p>\n        <div class=\"tag-group\" data-kid=\"91\">\n          <span class=\"tag\" data-kid=\"92\">embedded</span>\n          <span class=\"tag\" data-kid=\"93\">ARM/RISC-V</span>\n          <span class=\"tag\" data-kid=\"94\">WAL-safe</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"term-window reveal\" data-kid=\"95\">\n      <div class=\"term-header\" data-kid=\"96\">\n        <div class=\"dot dot-red\" data-kid=\"97\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"98\"></div>\n        <div class=\"dot dot-green\" data-kid=\"99\"></div>\n        <span class=\"term-label\" data-kid=\"100\">healthcare.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"101\">\n        <h3 class=\"uc-title\" data-kid=\"102\">Healthcare RAG</h3>\n        <p class=\"uc-desc\" data-kid=\"103\">Private medical RAG on-device. PHI stays local — no data leaves the hospital network, ensuring zero-trust compliance.</p>\n        <div class=\"tag-group\" data-kid=\"104\">\n          <span class=\"tag\" data-kid=\"105\">PHI-safe</span>\n          <span class=\"tag\" data-kid=\"106\">audit log</span>\n          <span class=\"tag\" data-kid=\"107\">zero-server</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"term-window reveal\" data-kid=\"108\">\n      <div class=\"term-header\" data-kid=\"109\">\n        <div class=\"dot dot-red\" data-kid=\"110\"></div>\n        <div class=\"dot dot-yellow\" data-kid=\"111\"></div>\n        <div class=\"dot dot-green\" data-kid=\"112\"></div>\n        <span class=\"term-label\" data-kid=\"113\">finance.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"114\">\n        <h3 class=\"uc-title\" data-kid=\"115\">Financial Processing</h3>\n        <p class=\"uc-desc\" data-kid=\"116\">Index and search high-throughput documents with crash-safe durability. Thousands of records per second on a single thread.</p>\n        <div class=\"tag-group\" data-kid=\"117\">\n          <span class=\"tag\" data-kid=\"118\">compliance</span>\n          <span class=\"tag\" data-kid=\"119\">high-throughput</span>\n          <span class=\"tag\" data-kid=\"120\">WAL</span>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<section class=\"pipeline-section\" data-kid=\"121\">\n  <div class=\"container\" data-kid=\"122\">\n    <div class=\"pipeline-header reveal\" data-kid=\"123\">\n      <span class=\"mono-label\" data-kid=\"124\">// CORE PIPELINE</span>\n      <h2 style=\"font-size: 2.5rem; margin-top: 16px;\" data-kid=\"125\">Memory → Search → Persist</h2>\n    </div>\n    \n    <div class=\"pipeline-grid\" data-kid=\"126\">\n      <div class=\"pipeline-item reveal\" data-kid=\"127\">\n        <div class=\"pipeline-step\" data-kid=\"128\">01</div>\n        <h3 class=\"pipeline-title\" data-kid=\"129\">Memory</h3>\n        <p class=\"pipeline-desc\" data-kid=\"130\">Embeddings and metadata written to the engine with immediate durability. The WAL guarantees crash recovery — every byte journaled.</p>\n      </div>\n      <div class=\"pipeline-item reveal\" style=\"transition-delay: 0.2s;\" data-kid=\"131\">\n        <div class=\"pipeline-step\" data-kid=\"132\">02</div>\n        <h3 class=\"pipeline-title\" data-kid=\"133\">Search</h3>\n        <p class=\"pipeline-desc\" data-kid=\"134\">HNSW + BM25 fused via RRF in a single call. Sub-millisecond latency with zero network — all computation is in-process memory.</p>\n      </div>\n      <div class=\"pipeline-item reveal\" style=\"transition-delay: 0.4s;\" data-kid=\"135\">\n        <div class=\"pipeline-step\" data-kid=\"136\">03</div>\n        <h3 class=\"pipeline-title\" data-kid=\"137\">Persist</h3>\n        <p class=\"pipeline-desc\" data-kid=\"138\">Everything in a single portable DB file. Move across machines, survive process kills — no reindexing, no cloud egress.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<footer data-kid=\"139\">\n  <div class=\"container\" data-kid=\"140\">\n    <span class=\"mono-label\" data-kid=\"141\">© 2026 VANTADB — BEYOND CLOUD LIMITS</span>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"142\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"143\"></script>\n<script data-kid=\"144\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Scroll Reveal\n  gsap.utils.toArray('.reveal').forEach(el => {\n    gsap.from(el, {\n      scrollTrigger: {\n        trigger: el,\n        start: 'top 85%',\n        toggleActions: 'play none none none'\n      },\n      opacity: 0,\n      y: 30,\n      duration: 1,\n      ease: 'power3.out'\n    });\n  });\n\n  // Micro-interaction: Tag pulsing\n  gsap.to('.tag', {\n    opacity: 0.8,\n    duration: 1.5,\n    repeat: -1,\n    yoyo: true,\n    ease: 'sine.inOut',\n    stagger: 0.1\n  });\n</script>",
