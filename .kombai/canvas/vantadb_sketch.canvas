      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600&family=Outfit:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --void: #050507;\n    --surface: #0f1014;\n    --raised: #16181d;\n    --amber: #ff6a00;\n    --steel: #8b9eb7;\n    --foreground: #f7f5f2;\n    --border: #22252b;\n    --success: #28c840;\n    --warn: #febc2e;\n    \n    --font-display: 'Space Grotesk', sans-serif;\n    --font-body: 'Outfit', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--void);\n    color: var(--foreground);\n    font-family: var(--font-body);\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  /* Typography */\n  .text-display { font-family: var(--font-display); font-size: clamp(3.5rem, 7vw, 6.5rem); line-height: 1; letter-spacing: -0.035em; }\n  .text-headline { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem); line-height: 1.1; letter-spacing: -0.03em; }\n  .text-label { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; }\n  .text-steel { color: var(--steel); }\n  .text-amber { color: var(--amber); }\n\n  /* Scanlines Overlay */\n  .scanlines {\n    position: fixed;\n    inset: 0;\n    background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.05) 50%);\n    background-size: 100% 4px;\n    pointer-events: none;\n    z-index: 100;\n    opacity: 0.15;\n    animation: scanline-drift 20s linear infinite;\n  }\n  @keyframes scanline-drift {\n    from { background-position: 0 0; }\n    to { background-position: 0 100%; }\n  }\n\n  /* Navigation */\n  nav {\n    position: fixed;\n    top: 0;\n    width: 100%;\n    height: 64px;\n    background: rgba(5, 5, 7, 0.8);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid var(--border);\n    z-index: 1000;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 0 40px;\n  }\n\n  .nav-links { display: flex; gap: 32px; }\n  .nav-link { \n    text-decoration: none; \n    color: var(--steel); \n    transition: color 0.2s;\n  }\n  .nav-link:hover { color: var(--amber); }\n\n  /* Hero */\n  .hero {\n    height: 100vh;\n    display: flex;\n    align-items: center;\n    position: relative;\n    padding: 0 10%;\n    overflow: hidden;\n  }\n  .hero-video {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    opacity: 0.35;\n    z-index: -1;\n  }\n  .hero-grid {\n    position: absolute;\n    inset: 0;\n    background-image: radial-gradient(var(--border) 1px, transparent 1px);\n    background-size: 40px 40px;\n    opacity: 0.2;\n    z-index: -1;\n  }\n  .hero-cursor {\n    display: inline-block;\n    width: 0.6em;\n    height: 1em;\n    background: var(--amber);\n    margin-left: 12px;\n    vertical-align: middle;\n    box-shadow: 0 0 15px var(--amber);\n    animation: blink 1s step-end infinite;\n  }\n  @keyframes blink { 50% { opacity: 0; } }\n\n  .btn-primary {\n    background: var(--amber);\n    color: #000;\n    padding: 14px 36px;\n    border-radius: 999px;\n    font-family: var(--font-mono);\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    border: none;\n    cursor: pointer;\n    display: inline-block;\n  }\n\n  /* Metrics Strip (htop style) */\n  .metrics-strip {\n    background: var(--surface);\n    border-top: 1px solid var(--border);\n    border-bottom: 1px solid var(--border);\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n  }\n  .metric-item {\n    padding: 32px;\n    border-right: 1px solid var(--border);\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n  .metric-item:last-child { border-right: none; }\n  .htop-bar {\n    height: 6px;\n    background: var(--border);\n    width: 100%;\n    position: relative;\n    overflow: hidden;\n    display: flex;\n    gap: 2px;\n  }\n  .htop-segment {\n    flex: 1;\n    height: 100%;\n    background: var(--border);\n  }\n  .metric-val { font-family: var(--font-display); font-size: 2.5rem; line-height: 1; }\n\n  /* Engine Scroller */\n  .scroller-section {\n    padding: 100px 10%;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 100px;\n    position: relative;\n  }\n  .sticky-visual {\n    position: sticky;\n    top: 120px;\n    height: calc(100vh - 240px);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .terminal-card {\n    width: 100%;\n    background: var(--raised);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    overflow: hidden;\n    box-shadow: 0 30px 60px rgba(0,0,0,0.5);\n    display: flex;\n    flex-direction: column;\n  }\n  .term-header {\n    height: 40px;\n    background: #1c1e24;\n    padding: 0 16px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    border-bottom: 1px solid var(--border);\n  }\n  .term-dot { width: 10px; height: 10px; border-radius: 50%; }\n  .term-body {\n    flex: 1;\n    padding: 32px;\n    font-family: var(--font-mono);\n    font-size: 0.95rem;\n    color: var(--steel);\n    min-height: 380px;\n  }\n\n  .text-panels { padding: 100px 0; }\n  .panel-item { min-height: 50vh; display: flex; flex-direction: column; justify-content: center; padding: 100px 0; }\n\n  /* Context Comparison */\n  .context-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 48px;\n    padding: 120px 10%;\n    background: var(--surface);\n    border-top: 1px solid var(--border);\n    border-bottom: 1px solid var(--border);\n  }\n\n  /* FFI Bridge */\n  .ffi-section {\n    padding: 120px 10%;\n    text-align: center;\n  }\n  .bridge-container {\n    margin-top: 64px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 40px;\n    max-width: 1000px;\n    margin-inline: auto;\n  }\n  .bridge-node {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    padding: 32px;\n    border-radius: 16px;\n    width: 200px;\n    transition: border-color 0.3s;\n  }\n  .bridge-node:hover { border-color: var(--amber); }\n  .bridge-line {\n    flex: 1;\n    height: 2px;\n    background: linear-gradient(90deg, #3776ab, var(--amber), #dea584);\n    position: relative;\n    overflow: hidden;\n  }\n  .data-packet {\n    position: absolute;\n    top: 50%;\n    left: -10px;\n    width: 6px;\n    height: 6px;\n    background: var(--foreground);\n    border-radius: 50%;\n    transform: translateY(-50%);\n    box-shadow: 0 0 10px var(--foreground);\n  }\n  .bridge-line::before {\n    content: 'ZERO-COPY BUFFER';\n    position: absolute;\n    top: -24px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-family: var(--font-mono);\n    font-size: 0.65rem;\n    color: var(--amber);\n  }\n\n  /* Ecosystem Registry */\n  .eco-section { padding: 120px 10%; }\n  .eco-grid {\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n    margin-top: 64px;\n    max-width: 900px;\n    margin-inline: auto;\n  }\n  .eco-card {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    padding: 24px 32px;\n    border-radius: 8px;\n    display: flex;\n    align-items: center;\n    gap: 24px;\n    position: relative;\n    transition: background 0.2s, border-color 0.2s;\n  }\n  .eco-card:hover {\n    background: var(--raised);\n    border-color: var(--amber);\n  }\n  .status-badge {\n    position: absolute;\n    top: 24px;\n    right: 24px;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    padding: 4px 10px;\n    background: rgba(0,0,0,0.3);\n    border-radius: 4px;\n    border: 1px solid var(--border);\n  }\n  .status-dot { width: 6px; height: 6px; border-radius: 50%; }\n\n  /* Final CTA */\n  .final-cta {\n    padding: 120px 0;\n    text-align: center;\n    position: relative;\n    overflow: hidden;\n  }\n  .singularity {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 600px;\n    height: 600px;\n    border: 1px solid var(--amber);\n    border-radius: 50%;\n    opacity: 0.15;\n    z-index: -1;\n    box-shadow: 0 0 80px rgba(255, 106, 0, 0.2);\n    animation: pulse 6s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.1; }\n    50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.25; }\n  }\n\n  /* Footer */\n  footer {\n    padding: 100px 10% 40px;\n    border-top: 1px solid var(--border);\n    background: var(--void);\n  }\n  .footer-grid {\n    display: grid;\n    grid-template-columns: 2fr 1fr 1fr 1fr;\n    gap: 60px;\n    margin-bottom: 80px;\n  }\n  .footer-col h4 { margin-bottom: 24px; color: var(--foreground); }\n  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }\n  .footer-links a { text-decoration: none; color: var(--steel); transition: color 0.2s; font-size: 0.95rem; }\n  .footer-links a:hover { color: var(--amber); }\n\n  .btn-ghost {\n    background: transparent;\n    border: 1px solid rgba(255, 106, 0, 0.3);\n    color: var(--amber);\n    padding: 14px 36px;\n    border-radius: 999px;\n    font-family: var(--font-mono);\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    cursor: pointer;\n    transition: all 0.2s;\n  }\n  .btn-ghost:hover { background: rgba(255, 106, 0, 0.08); border-color: var(--amber); }\n\n  /* Code Syntax Highlighting */\n  .syntax-keyword { color: var(--amber); }\n  .syntax-string { color: #a3be8c; }\n  .syntax-comment { color: #5c6370; font-style: italic; }\n  .syntax-func { color: #61afef; }\n</style>\n\n<div class=\"scanlines\" data-kid=\"1\"></div>\n\n<nav data-kid=\"2\">\n  <div class=\"text-label\" style=\"display: flex; align-items: center; gap: 12px; font-weight: 600; font-size: 1rem; color: var(--foreground);\" data-kid=\"3\">\n    <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"4\"><path d=\"M12 2L2 22H22L12 2Z\" stroke=\"#ff6a00\" stroke-width=\"2\" stroke-linejoin=\"round\" data-kid=\"5\"></path></svg>\n    VANTADB\n  </div>\n  <div class=\"nav-links\" data-kid=\"6\">\n    <a href=\"#engine\" class=\"nav-link text-label\" data-kid=\"7\">Engine</a>\n    <a href=\"#architecture\" class=\"nav-link text-label\" data-kid=\"8\">Architecture</a>\n    <a href=\"#ecosystem\" class=\"nav-link text-label\" data-kid=\"9\">Ecosystem</a>\n    <a href=\"#\" class=\"nav-link text-label\" data-kid=\"10\">Docs</a>\n  </div>\n  <div class=\"nav-links\" data-kid=\"11\">\n    <a href=\"#\" class=\"nav-link text-label\" data-kid=\"12\">GitHub</a>\n  </div>\n</nav>\n\n<section class=\"hero\" data-kid=\"13\">\n  <video class=\"hero-video\" src=\"https://videos.pexels.com/video-files/10296171/10296171-hd_1920_1080_25fps.mp4\" poster=\"https://images.pexels.com/videos/10296171/pexels-photo-10296171.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" data-kid=\"14\"></video>\n  <div class=\"hero-grid\" data-kid=\"15\"></div>\n  <div style=\"max-width: 900px; position: relative; z-index: 2;\" data-kid=\"16\">\n    <span class=\"text-label text-steel\" style=\"margin-bottom: 24px; display: block;\" data-kid=\"17\">// EMBEDDED RUST CORE v0.4.2</span>\n    <h1 class=\"text-display\" data-kid=\"18\">Memory that<br data-kid=\"19\">never escapes<span class=\"hero-cursor\" data-kid=\"20\"></span></h1>\n    <p class=\"text-steel\" style=\"font-size: 1.35rem; margin: 32px 0 48px; max-width: 650px; line-height: 1.6;\" data-kid=\"21\">\n      The unified engine for AI agents. Hybrid search (BM25 + HNSW) and GraphRAG in a single, process-local binary.\n    </p>\n    <div style=\"display: flex; gap: 32px; align-items: center;\" data-kid=\"22\">\n      <button class=\"btn-primary\" id=\"magnetic-pip\" data-kid=\"23\">pip install vantadb-py</button>\n      <a href=\"#\" class=\"text-label text-amber\" style=\"text-decoration: none; border-bottom: 1px solid var(--amber); padding-bottom: 2px;\" data-kid=\"24\">\n        <span class=\"text-steel\" style=\"margin-right: 8px;\" data-kid=\"25\">$</span> read_schematic --verbose\n      </a>\n    </div>\n  </div>\n</section>\n\n<section class=\"metrics-strip\" data-kid=\"26\">\n  <div class=\"metric-item\" data-kid=\"27\">\n    <div style=\"display: flex; justify-content: space-between; align-items: flex-end;\" data-kid=\"28\">\n      <span class=\"text-label text-steel\" data-kid=\"29\">P99_QUERY_LATENCY</span>\n      <span class=\"metric-val\" data-kid=\"30\">1.2ms</span>\n    </div>\n    <div class=\"htop-bar\" data-progress=\"15\" data-kid=\"31\"></div>\n  </div>\n  <div class=\"metric-item\" data-kid=\"32\">\n    <div style=\"display: flex; justify-content: space-between; align-items: flex-end;\" data-kid=\"33\">\n      <span class=\"text-label text-steel\" data-kid=\"34\">MAX_VECTOR_DIMS</span>\n      <span class=\"metric-val\" data-kid=\"35\">32K</span>\n    </div>\n    <div class=\"htop-bar\" data-progress=\"85\" data-kid=\"36\"></div>\n  </div>\n  <div class=\"metric-item\" data-kid=\"37\">\n    <div style=\"display: flex; justify-content: space-between; align-items: flex-end;\" data-kid=\"38\">\n      <span class=\"text-label text-steel\" data-kid=\"39\">BM25_RECALL_ACC</span>\n      <span class=\"metric-val\" data-kid=\"40\">100%</span>\n    </div>\n    <div class=\"htop-bar\" data-progress=\"100\" data-kid=\"41\"></div>\n  </div>\n  <div class=\"metric-item\" data-kid=\"42\">\n    <div style=\"display: flex; justify-content: space-between; align-items: flex-end;\" data-kid=\"43\">\n      <span class=\"text-label text-steel\" data-kid=\"44\">EXTERNAL_RUNTIME_DEPS</span>\n      <span class=\"metric-val\" data-kid=\"45\">0</span>\n    </div>\n    <div class=\"htop-bar\" data-progress=\"0\" data-kid=\"46\"></div>\n  </div>\n</section>\n\n<section class=\"scroller-section\" id=\"engine\" data-kid=\"47\">\n  <div class=\"text-panels\" data-kid=\"48\">\n    <div class=\"panel-item\" id=\"trigger-bm25\" data-kid=\"49\">\n      <span class=\"text-label text-amber\" style=\"margin-bottom: 16px; display: block;\" data-kid=\"50\">01 // LEXICAL SEARCH</span>\n      <h2 class=\"text-headline\" style=\"margin-bottom: 24px;\" data-kid=\"51\">BM25 Text Search</h2>\n      <p class=\"text-steel\" style=\"font-size: 1.2rem; line-height: 1.7; max-width: 500px;\" data-kid=\"52\">\n        Full-text search at 1.2ms p99. No sidecars, no separate indexing pipelines. The Rust engine embeds directly into your Python process.\n      </p>\n    </div>\n    <div class=\"panel-item\" id=\"trigger-hnsw\" data-kid=\"53\">\n      <span class=\"text-label text-amber\" style=\"margin-bottom: 16px; display: block;\" data-kid=\"54\">02 // VECTOR SEARCH</span>\n      <h2 class=\"text-headline\" style=\"margin-bottom: 24px;\" data-kid=\"55\">HNSW Graph Index</h2>\n      <p class=\"text-steel\" style=\"font-size: 1.2rem; line-height: 1.7; max-width: 500px;\" data-kid=\"56\">\n        Hierarchical Navigable Small World graphs for high-dim nearest neighbor search. Sub-millisecond recall for up to 32K dimensions.\n      </p>\n    </div>\n    <div class=\"panel-item\" id=\"trigger-graph\" data-kid=\"57\">\n      <span class=\"text-label text-amber\" style=\"margin-bottom: 16px; display: block;\" data-kid=\"58\">03 // GRAPH RELATIONS</span>\n      <h2 class=\"text-headline\" style=\"margin-bottom: 24px;\" data-kid=\"59\">GraphRAG Core</h2>\n      <p class=\"text-steel\" style=\"font-size: 1.2rem; line-height: 1.7; max-width: 500px;\" data-kid=\"60\">\n        Weighted-edge graph relations with 0.2ms traversal. Enables multi-hop reasoning across agent memory within a single WAL journal.\n      </p>\n    </div>\n  </div>\n\n  <div class=\"sticky-visual\" data-kid=\"61\">\n    <div class=\"terminal-card\" data-kid=\"62\">\n      <div class=\"term-header\" data-kid=\"63\">\n        <div class=\"term-dot\" style=\"background: var(--border);\" data-kid=\"64\"></div>\n        <div class=\"term-dot\" style=\"background: var(--border);\" data-kid=\"65\"></div>\n        <div class=\"term-dot\" style=\"background: var(--amber); opacity: 0.5;\" data-kid=\"66\"></div>\n        <span class=\"text-label\" style=\"margin-left: auto; opacity: 0.5;\" data-kid=\"67\">vantadb_core.py</span>\n      </div>\n      <div class=\"term-body\" id=\"terminal-content\" data-kid=\"68\">\n        <pre data-kid=\"69\"><code id=\"code-display\" style=\"line-height: 1.6;\">\n<span class=\"syntax-keyword\">import</span> vantadb\n\ndb = vantadb.connect(<span class=\"syntax-string\">\"./context\"</span>)\ndb.insert(<span class=\"syntax-string\">\"doc_1\"</span>, text=<span class=\"syntax-string\">\"Agent memory node...\"</span>)\n\n<span class=\"syntax-comment\"># 1.2ms Lexical Query</span>\nresults = db.search(<span class=\"syntax-string\">\"agent\"</span>, mode=<span class=\"syntax-string\">\"bm25\"</span>)</code></pre>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"context-grid\" data-kid=\"70\">\n  <div data-kid=\"71\">\n    <span class=\"text-label text-amber\" style=\"margin-bottom: 16px; display: block;\" data-kid=\"72\">// USE CASE</span>\n    <h2 class=\"text-headline\" data-kid=\"73\">Context that never fragments.</h2>\n    <p class=\"text-steel\" style=\"font-size: 1.2rem; line-height: 1.7; margin: 32px 0 48px;\" data-kid=\"74\">\n      Traditional databases separate lexical and vector data. VantaDB collapses the stack into a single Rust binary, enabling multi-hop reasoning across your agent's entire memory.\n    </p>\n    \n    <div class=\"terminal-card\" style=\"background: var(--void); opacity: 0.8;\" data-kid=\"75\">\n      <div class=\"term-header\" data-kid=\"76\">\n        <span class=\"text-label\" style=\"opacity: 0.5;\" data-kid=\"77\">MEMORY_TRACE.LOG</span>\n      </div>\n      <div class=\"term-body\" style=\"font-size: 0.8rem; padding: 20px;\" data-kid=\"78\">\n        <div class=\"text-steel\" data-kid=\"79\">[02:18:33] BM25: Found 12 matches</div>\n        <div class=\"text-steel\" data-kid=\"80\">[02:18:33] HNSW: Reranked top 5</div>\n        <div class=\"text-steel\" data-kid=\"81\">[02:18:34] Graph: Resolved relation</div>\n        <div class=\"text-steel\" data-kid=\"82\">[02:18:34] Total context: 4.2kb</div>\n        <div class=\"text-amber\" data-kid=\"83\">[02:18:34] Latency: 0.84ms</div>\n      </div>\n    </div>\n  </div>\n  \n  <div style=\"display: flex; align-items: center; justify-content: center; position: relative;\" data-kid=\"84\">\n    <div class=\"terminal-card\" style=\"width: 100%;\" data-kid=\"85\">\n      <div class=\"term-header\" data-kid=\"86\">\n        <span class=\"text-label\" style=\"opacity: 0.5;\" data-kid=\"87\">agent_memory.py</span>\n      </div>\n      <div class=\"term-body\" data-kid=\"88\">\n        <pre data-kid=\"89\"><code><span class=\"syntax-keyword\">import</span> vantadb\n\ndb = vantadb.connect(<span class=\"syntax-string\">\"./memory\"</span>)\n\n<span class=\"syntax-comment\"># Hybrid search in 1.2ms</span>\ncontext = db.query(\n  vector=[<span style=\"color: #d19a66;\">0.12, 0.45, ...</span>],\n  text=<span class=\"syntax-string\">\"deployment logs\"</span>,\n  top_k=<span style=\"color: #d19a66;\">5</span>\n)</code></pre>\n      </div>\n    </div>\n    <div style=\"position: absolute; top: -40px; right: -40px; opacity: 0.05;\" data-kid=\"90\">\n      <i class=\"ti ti-mesh\" style=\"font-size: 300px;\" data-kid=\"91\"></i>\n    </div>\n  </div>\n</section>\n\n<section class=\"ffi-section\" id=\"architecture\" data-kid=\"92\">\n  <span class=\"text-label text-steel\" data-kid=\"93\">// ARCHITECTURE</span>\n  <h2 class=\"text-headline\" style=\"margin-top: 16px;\" data-kid=\"94\">Zero-copy FFI bridge.</h2>\n  <p class=\"text-steel\" style=\"max-width: 600px; margin: 24px auto 0; font-size: 1.15rem;\" data-kid=\"95\">\n    Built on PyO3 for zero-serialization overhead between Python and the Rust engine. \n    Your data stays in memory, shared across the language boundary.\n  </p>\n  \n  <div class=\"bridge-container\" data-kid=\"96\">\n    <div class=\"bridge-node\" data-kid=\"97\">\n      <span class=\"text-label\" style=\"color: #3776ab;\" data-kid=\"98\">Python</span>\n      <div style=\"margin-top: 20px;\" data-kid=\"99\"><i class=\"ti ti-brand-python\" style=\"font-size: 3rem; color: #3776ab;\" data-kid=\"100\"></i></div>\n    </div>\n    <div class=\"bridge-line\" data-kid=\"101\">\n      <div class=\"data-packet\" data-kid=\"102\"></div>\n    </div>\n    <div class=\"bridge-node\" data-kid=\"103\">\n      <span class=\"text-label\" style=\"color: #dea584;\" data-kid=\"104\">Rust Core</span>\n      <div style=\"margin-top: 20px;\" data-kid=\"105\"><i class=\"ti ti-brand-rust\" style=\"font-size: 3rem; color: #dea584;\" data-kid=\"106\"></i></div>\n    </div>\n  </div>\n  \n  <div style=\"margin-top: 80px; max-width: 800px; margin-inline: auto; background: var(--surface); border: 1px solid var(--border); padding: 32px; border-radius: 12px; text-align: left;\" data-kid=\"107\">\n    <span class=\"text-label text-steel\" style=\"display: block; margin-bottom: 16px;\" data-kid=\"108\">FLAMEGRAPH_SESSION_ID: 0XF2A1</span>\n    <div style=\"height: 120px; display: flex; align-items: flex-end; gap: 6px;\" data-kid=\"109\">\n      <div style=\"flex: 1; height: 30%; background: var(--amber); opacity: 0.2;\" data-kid=\"110\"></div>\n      <div style=\"flex: 1; height: 55%; background: var(--amber); opacity: 0.4;\" data-kid=\"111\"></div>\n      <div style=\"flex: 1; height: 90%; background: var(--amber); opacity: 0.7;\" data-kid=\"112\"></div>\n      <div style=\"flex: 1; height: 100%; background: var(--amber); opacity: 1;\" data-kid=\"113\"></div>\n      <div style=\"flex: 1; height: 65%; background: var(--amber); opacity: 0.6;\" data-kid=\"114\"></div>\n      <div style=\"flex: 1; height: 40%; background: var(--amber); opacity: 0.3;\" data-kid=\"115\"></div>\n      <div style=\"flex: 1; height: 20%; background: var(--amber); opacity: 0.1;\" data-kid=\"116\"></div>\n    </div>\n  </div>\n</section>\n\n<section class=\"eco-section\" id=\"ecosystem\" data-kid=\"117\">\n  <div style=\"text-align: center;\" data-kid=\"118\">\n    <span class=\"text-label text-steel\" data-kid=\"119\">// COMMAND CENTER</span>\n    <h2 class=\"text-headline\" style=\"margin-top: 16px;\" data-kid=\"120\">Drop-in for any agent framework.</h2>\n  </div>\n  \n  <div class=\"eco-grid\" data-kid=\"121\">\n    <div class=\"eco-card\" data-kid=\"122\">\n      <i class=\"ti ti-box\" style=\"font-size: 2rem; color: var(--steel);\" data-kid=\"123\"></i>\n      <div style=\"flex: 1;\" data-kid=\"124\">\n        <h3 class=\"text-label\" style=\"font-size: 1rem; color: var(--foreground); margin-bottom: 4px;\" data-kid=\"125\">LangChain VectorStore</h3>\n        <p class=\"text-steel\" style=\"font-size: 0.9rem;\" data-kid=\"126\">Official protocol implementation for high-throughput retrieval chains.</p>\n      </div>\n      <div class=\"status-badge\" style=\"position: static;\" data-kid=\"127\">\n        <span class=\"status-dot\" style=\"background: var(--success);\" data-kid=\"128\"></span>\n        <span class=\"text-label\" style=\"font-size: 0.6rem;\" data-kid=\"129\">STABLE</span>\n      </div>\n    </div>\n    \n    <div class=\"eco-card\" data-kid=\"130\">\n      <i class=\"ti ti-route\" style=\"font-size: 2rem; color: var(--steel);\" data-kid=\"131\"></i>\n      <div style=\"flex: 1;\" data-kid=\"132\">\n        <h3 class=\"text-label\" style=\"font-size: 1rem; color: var(--foreground); margin-bottom: 4px;\" data-kid=\"133\">LlamaIndex Integration</h3>\n        <p class=\"text-steel\" style=\"font-size: 0.9rem;\" data-kid=\"134\">Native traversal engine for recursive multi-hop RAG pipelines.</p>\n      </div>\n      <div class=\"status-badge\" style=\"position: static;\" data-kid=\"135\">\n        <span class=\"status-dot\" style=\"background: var(--success);\" data-kid=\"136\"></span>\n        <span class=\"text-label\" style=\"font-size: 0.6rem;\" data-kid=\"137\">STABLE</span>\n      </div>\n    </div>\n    \n    <div class=\"eco-card\" data-kid=\"138\">\n      <i class=\"ti ti-navigation\" style=\"font-size: 2rem; color: var(--steel);\" data-kid=\"139\"></i>\n      <div style=\"flex: 1;\" data-kid=\"140\">\n        <h3 class=\"text-label\" style=\"font-size: 1rem; color: var(--foreground); margin-bottom: 4px;\" data-kid=\"141\">AutoGen Memory Store</h3>\n        <p class=\"text-steel\" style=\"font-size: 0.9rem;\" data-kid=\"142\">Long-term persistent context for multi-agent swarm collaboration.</p>\n      </div>\n      <div class=\"status-badge\" style=\"position: static;\" data-kid=\"143\">\n        <span class=\"status-dot\" style=\"background: var(--warn);\" data-kid=\"144\"></span>\n        <span class=\"text-label\" style=\"font-size: 0.6rem;\" data-kid=\"145\">BETA</span>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"final-cta\" data-kid=\"146\">\n  <div class=\"singularity\" data-kid=\"147\"></div>\n  <div style=\"position: relative; z-index: 2;\" data-kid=\"148\">\n    <h2 class=\"text-display\" data-kid=\"149\">Context that<br data-kid=\"150\"><span class=\"text-amber\" data-kid=\"151\">never fragments.</span></h2>\n    <p class=\"text-steel\" style=\"font-size: 1.35rem; margin: 40px 0 60px;\" data-kid=\"152\">Apache 2.0 — Built in Rust — Run anywhere.</p>\n    <button class=\"btn-ghost\" style=\"padding: 16px 60px;\" data-kid=\"153\">Explore the Documentation</button>\n  </div>\n</section>\n\n<footer data-kid=\"154\">\n  <div class=\"footer-grid\" data-kid=\"155\">\n    <div class=\"footer-col\" data-kid=\"156\">\n      <div class=\"text-label\" style=\"display: flex; align-items: center; gap: 12px; font-weight: 600; font-size: 1.25rem; color: var(--foreground); margin-bottom: 24px;\" data-kid=\"157\">\n        <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"158\"><path d=\"M12 2L2 22H22L12 2Z\" stroke=\"#ff6a00\" stroke-width=\"2\" stroke-linejoin=\"round\" data-kid=\"159\"></path></svg>\n        VANTADB\n      </div>\n      <p class=\"text-steel\" style=\"max-width: 320px; line-height: 1.6;\" data-kid=\"160\">\n        The embedded cognitive memory engine for AI agents. Open source, binary-efficient, and process-local.\n      </p>\n    </div>\n    <div class=\"footer-col\" data-kid=\"161\">\n      <h4 class=\"text-label\" data-kid=\"162\">Product</h4>\n      <ul class=\"footer-links\" data-kid=\"163\">\n        <li data-kid=\"164\"><a href=\"#\" data-kid=\"165\">Engine</a></li>\n        <li data-kid=\"166\"><a href=\"#\" data-kid=\"167\">Benchmarks</a></li>\n        <li data-kid=\"168\"><a href=\"#\" data-kid=\"169\">Integrations</a></li>\n        <li data-kid=\"170\"><a href=\"#\" data-kid=\"171\">Security</a></li>\n      </ul>\n    </div>\n    <div class=\"footer-col\" data-kid=\"172\">\n      <h4 class=\"text-label\" data-kid=\"173\">Ecosystem</h4>\n      <ul class=\"footer-links\" data-kid=\"174\">\n        <li data-kid=\"175\"><a href=\"#\" data-kid=\"176\">GitHub</a></li>\n        <li data-kid=\"177\"><a href=\"#\" data-kid=\"178\">Discord</a></li>\n        <li data-kid=\"179\"><a href=\"#\" data-kid=\"180\">Twitter</a></li>\n        <li data-kid=\"181\"><a href=\"#\" data-kid=\"182\">Docs</a></li>\n      </ul>\n    </div>\n    <div class=\"footer-col\" data-kid=\"183\">\n      <h4 class=\"text-label\" data-kid=\"184\">Legal</h4>\n      <ul class=\"footer-links\" data-kid=\"185\">\n        <li data-kid=\"186\"><a href=\"#\" data-kid=\"187\">Privacy</a></li>\n        <li data-kid=\"188\"><a href=\"#\" data-kid=\"189\">Terms</a></li>\n        <li data-kid=\"190\"><a href=\"#\" data-kid=\"191\">License</a></li>\n      </ul>\n    </div>\n  </div>\n  <div style=\"display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 40px;\" data-kid=\"192\">\n    <span class=\"text-label text-steel\" style=\"font-size: 0.65rem;\" data-kid=\"193\">© 2026 VANTADB SYSTEM — ALL RIGHTS RESERVED</span>\n    <span class=\"text-label text-steel\" style=\"font-size: 0.65rem;\" data-kid=\"194\">VER_0.4.2_STABLE</span>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"195\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"196\"></script>\n<script data-kid=\"197\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Magnetic button logic\n  const btn = document.querySelector('#magnetic-pip');\n  const xTo = gsap.quickTo(btn, \"x\", {duration: 0.3, ease: \"power3\"});\n  const yTo = gsap.quickTo(btn, \"y\", {duration: 0.3, ease: \"power3\"});\n\n  window.addEventListener(\"mousemove\", e => {\n    const rect = btn.getBoundingClientRect();\n    const btnCenterX = rect.left + rect.width / 2;\n    const btnCenterY = rect.top + rect.height / 2;\n    const distance = Math.sqrt(Math.pow(e.clientX - btnCenterX, 2) + Math.pow(e.clientY - btnCenterY, 2));\n\n    if (distance < 150) {\n      xTo((e.clientX - btnCenterX) * 0.2);\n      yTo((e.clientY - btnCenterY) * 0.2);\n    } else {\n      xTo(0);\n      yTo(0);\n    }\n  });\n\n  // Metrics reveal (segmented htop)\n  gsap.utils.toArray('.htop-bar').forEach(bar => {\n    const progress = parseInt(bar.getAttribute('data-progress'));\n    const segmentsCount = 20;\n    const activeSegments = Math.round((progress / 100) * segmentsCount);\n\n    for (let i = 0; i < segmentsCount; i++) {\n      const seg = document.createElement('div');\n      seg.className = 'htop-segment';\n      bar.appendChild(seg);\n    }\n\n    const segments = bar.querySelectorAll('.htop-segment');\n    gsap.to(segments, {\n      scrollTrigger: {\n        trigger: '.metrics-strip',\n        start: 'top 80%',\n      },\n      backgroundColor: (i) => i < activeSegments ? '#ff6a00' : '#22252b',\n      stagger: 0.05,\n      duration: 0.1,\n      ease: 'none'\n    });\n  });\n\n  // FFI Data packet animation\n  gsap.to('.data-packet', {\n    left: '100%',\n    duration: 1.5,\n    repeat: -1,\n    ease: 'power1.inOut',\n    stagger: {\n      each: 0.5,\n      repeat: -1\n    }\n  });\n\n  // Terminal morphing\n  const terminalStates = [\n    {\n      code: `<span class=\"syntax-keyword\">import</span> vantadb\n\ndb = vantadb.connect(<span class=\"syntax-string\">\"./context\"</span>)\ndb.insert(<span class=\"syntax-string\">\"doc_1\"</span>, text=<span class=\"syntax-string\">\"Agent memory node...\"</span>)\n\n<span class=\"syntax-comment\"># 1.2ms Lexical Query</span>\nresults = db.search(<span class=\"syntax-string\">\"agent\"</span>, mode=<span class=\"syntax-string\">\"bm25\"</span>)`\n    },\n    {\n      code: `<span class=\"syntax-comment\"># HNSW Vector Indexing</span>\nvector = embeddings.create(<span class=\"syntax-string\">\"Contextual data\"</span>)\n\ndb.upsert(<span class=\"syntax-string\">\"vec_1\"</span>, vector=vector)\n\n<span class=\"syntax-comment\"># Sub-ms Approximate Nearest Neighbor</span>\nresults = db.query_vectors(vector, limit=<span style=\"color: #d19a66;\">10</span>)`\n    },\n    {\n      code: `<span class=\"syntax-comment\"># GraphRAG Multi-hop Traversal</span>\ndb.add_relation(\n&nbsp;&nbsp;source=<span class=\"syntax-string\">\"doc_1\"</span>, \n&nbsp;&nbsp;target=<span class=\"syntax-string\">\"doc_2\"</span>, \n&nbsp;&nbsp;weight=<span style=\"color: #d19a66;\">0.85</span>\n)\n\n<span class=\"syntax-comment\"># 0.2ms Weighted Edge Discovery</span>\npath = db.traverse(<span class=\"syntax-string\">\"doc_1\"</span>, depth=<span style=\"color: #d19a66;\">3</span>)`\n    }\n  ];\n\n  const codeDisplay = document.querySelector('#code-display');\n  const termIcon = document.querySelector('#term-icon');\n\n  function switchTerminal(index) {\n    gsap.to('#terminal-content', {\n      opacity: 0,\n      y: 10,\n      duration: 0.3,\n      onComplete: () => {\n        codeDisplay.innerHTML = terminalStates[index].code;\n        gsap.to('#terminal-content', {\n          opacity: 1,\n          y: 0,\n          duration: 0.5\n        });\n      }\n    });\n  }\n\n  ScrollTrigger.create({\n    trigger: '#trigger-bm25',\n    start: 'top center',\n    onEnter: () => switchTerminal(0),\n    onEnterBack: () => switchTerminal(0)\n  });\n\n  ScrollTrigger.create({\n    trigger: '#trigger-hnsw',\n    start: 'top center',\n    onEnter: () => switchTerminal(1),\n    onEnterBack: () => switchTerminal(1)\n  });\n\n  ScrollTrigger.create({\n    trigger: '#trigger-graph',\n    start: 'top center',\n    onEnter: () => switchTerminal(2),\n    onEnterBack: () => switchTerminal(2)\n  });\n\n  // Purposeful reveals\n  gsap.from('.bridge-line', {\n    scrollTrigger: {\n      trigger: '.ffi-section',\n      start: 'top 80%'\n    },\n    scaleX: 0,\n    transformOrigin: 'left center',\n    duration: 1.5,\n    ease: 'power4.out'\n  });\n\n  // Singularity pulse & magnetic tracking\n  const singularity = document.querySelector('.singularity');\n  const sXTo = gsap.quickTo(singularity, \"x\", {duration: 0.6, ease: \"power2\"});\n  const sYTo = gsap.quickTo(singularity, \"y\", {duration: 0.6, ease: \"power2\"});\n\n  window.addEventListener(\"mousemove\", e => {\n    const rect = singularity.getBoundingClientRect();\n    const sCenterX = rect.left + rect.width / 2;\n    const sCenterY = rect.top + rect.height / 2;\n    const distance = Math.sqrt(Math.pow(e.clientX - sCenterX, 2) + Math.pow(e.clientY - sCenterY, 2));\n\n    if (distance < 500) {\n      sXTo((e.clientX - sCenterX) * 0.05);\n      sYTo((e.clientY - sCenterY) * 0.05);\n    } else {\n      sXTo(0);\n      sYTo(0);\n    }\n  });\n\n  gsap.to(singularity, {\n    scale: 1.1,\n    duration: 6,\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\"\n  });\n\n</script>\n",
      "comments": [],
      "created": "2026-06-22T02:33:16.347989+00:00",
      "modified": "2026-06-22T02:33:16.347989+00:00",
